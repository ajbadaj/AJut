<UserControl x:Class="TheAJutShowRoom.UI.Pages.UxStrategiesOverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TheAJutShowRoom.UI.Pages"
             xmlns:ajut_conv="clr-namespace:AJut.UX.Converters;assembly=AJut.UX.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Margin="20">
        <TextBlock FontSize="18" TextWrapping="WrapWithOverflow" Text="⚠ Under construction: This will one day list strategies included in ajut.ux.wpf, code examples, links to articles."
                   Foreground="{DynamicResource AJut_Brush_ImportantText}"/>
        <TextBlock Text="String to brush example" Margin="0,20,0,0"/>
        <RichTextBox IsReadOnly="True" IsReadOnlyCaretVisible="True"
                     Background="Transparent" BorderThickness="0">
            <RichTextBox.Document>
                <FlowDocument>
                    <Paragraph>
                        <Run Text="Setting the text below to a color like " Foreground="{DynamicResource AJut_Brush_NormalText}"/>
                        <Run Text="#F0F" FontFamily="Consolas" Foreground="#A22"/>
                        <Run Text=" will set the swatch below. Try more advanced things like: " Foreground="{DynamicResource AJut_Brush_NormalText}"/>
                        <Run Text="radial-gradient(circle at 25% 90%, #FF0000, #0000FF)" FontFamily="Consolas" Foreground="#A22"/>
                        <Run Text=" or "/>
                        <Run Text="linear-gradient(76deg, #A22, #0000FF)" FontFamily="Consolas" Foreground="#A22"/>
                    </Paragraph>
                </FlowDocument>
            </RichTextBox.Document>
        </RichTextBox>
        <TextBox x:Name="BackgroundMaker"/>
        <!-- The swatch that shows the background made -->
        <Grid Width="200" Height="200"  
              Background="{Binding ElementName=BackgroundMaker, Path=Text, Converter={ajut_conv:ColorStringToBrushConverter}}"/>
    </StackPanel>
</UserControl>
