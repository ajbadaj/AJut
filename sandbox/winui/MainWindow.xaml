<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AJutShowRoomWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ajut="using:AJut.UX.Controls"
    xmlns:ajut_conv="using:AJut.UX.Converters"
    xmlns:local="using:AJutShowRoomWinUI"
    xmlns:ajut_pg="using:AJut.UX.PropertyInteraction"
    mc:Ignorable="d"
    Title="AJut Showroom for WinUI"
    x:Name="Self">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <ajut:ThemedWindowRootControl x:Name="Root" TargetBorderThickness="2" TitleBarHeight="40" ShowFullscreenButtons="True"
                                  InactiveTitlebarBackground="{ThemeResource AJut_Brush_TitleBarBackgroundInactive}"
                                  CornerRadius="{Binding ElementName=Root, Path=IsMaximizedOrFullScreened, Converter={ajut_conv:BooleanToCornerRadiusConverter TrueValue='0', FalseValue='5'}}">
        <ajut:ThemedWindowRootControl.ActiveTitleBarBackground>
            <AcrylicBrush TintColor="{ThemeResource AJut_Color_TitleBarBackground}" TintLuminosityOpacity="1" TintOpacity="0.3" Opacity="0.8"/>
        </ajut:ThemedWindowRootControl.ActiveTitleBarBackground>
        <ajut:ThemedWindowRootControl.CustomTilteBar>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Path x:Name="JewelBkgPath" Data="M 0,0 L 40,0 L 60,20 L 40,40 L 0,40 Z" StrokeThickness="0">
                        <Path.Fill>
                            <Binding ElementName="Root" Path="LastState">
                                <Binding.Converter>
                                    <ajut_conv:StringToBrushSwitchConverter>
                                        <ajut_conv:StringToBrushSwitchConverter.Cases>
                                            <ajut_conv:BrushDictionary>
                                                <SolidColorBrush x:Key="CloseHover" Color="{ThemeResource AJut_Color_ChromeCloseButtonComplement}"/>
                                                <SolidColorBrush x:Key="ChromeButtonsHover" Color="{ThemeResource AJut_Color_PrimaryHighlightBright}"/>
                                                <SolidColorBrush x:Key="Normal" Color="{ThemeResource AJut_Color_PrimaryHighlight}"/>
                                                <SolidColorBrush x:Key="Inactive" Color="{ThemeResource AJut_Color_PrimaryHighlightDesat}"/>
                                            </ajut_conv:BrushDictionary>
                                        </ajut_conv:StringToBrushSwitchConverter.Cases>
                                    </ajut_conv:StringToBrushSwitchConverter>
                                </Binding.Converter>
                            </Binding>
                        </Path.Fill>
                    </Path>
                    <Image Source="/Assets/app.ico" Margin="3"/>
                </Grid>
                <Grid x:Name="TitleArea" Grid.Column="1">
                    <TextBlock Text="AJut Showroom: WinUI3" Foreground="{ThemeResource AJut_Brush_ImportantText}" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="18" HorizontalAlignment="Left"/>
                </Grid>
            </Grid>
        </ajut:ThemedWindowRootControl.CustomTilteBar>
        <Grid>
            <Border x:Name="Colorization"
                    BorderThickness="8,0,0,0" Margin="0,0,0,0" CornerRadius="0,0,0,0"
                    Background="{Binding ElementName=Root, Path=Background}"
                    BorderBrush="{Binding ElementName=JewelBkgPath, Path=Fill}">
                <TabView VerticalAlignment="Stretch">
                    <TabView.Resources>
                        <ResourceDictionary>
                            <x:Double x:Key="AJut_Double_TabViewStrokeThickness">1.0</x:Double>
                            <SolidColorBrush x:Key="TabViewBorderBrush" Color="{ThemeResource AJut_Color_Shadow}"/>
                        </ResourceDictionary>
                    </TabView.Resources>

                    <!-- ===[ Theme Test ]========================================================== -->
                    <TabViewItem Header="Theme Test" IsClosable="False">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="Highlight"/>
                        </TabViewItem.IconSource>
                        <TabViewItem.Content>
                            <ScrollViewer VerticalScrollMode="Enabled">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Width="500">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SpecificThemeText" Margin="0,0,5,0"/>
                                        <Button Grid.Column="1" Content="Resolve ThemeResource" Click="ThemeResolver_OnClick"/>
                                    </Grid>
                                    <ListBox x:Name="ThemeColorsList" Margin="0,10" MaxHeight="300" IsDoubleTapEnabled="True" DoubleTapped="ThemeColorsList_OnDoubleTapped" />
                                    <ColorPicker x:Name="ColorPicker"/>
                                    <MenuBar>
                                        <MenuBarItem Title="File">
                                            <MenuFlyoutItem Text="Open"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Exit"/>
                                        </MenuBarItem>
                                        <MenuBarItem Title="Edit">
                                            <MenuFlyoutItem Text="Copy"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Undo"/>
                                            <MenuFlyoutItem Text="Redo"/>
                                        </MenuBarItem>
                                    </MenuBar>
                                    <NumberBox Value="3.14159"/>
                                    <ToggleSwitch OnContent="Ready" OffContent="Invalid"/>
                                    <ToggleButton>Toggle</ToggleButton>
                                </StackPanel>
                            </ScrollViewer>
                        </TabViewItem.Content>
                    </TabViewItem>

                    <!-- ===[ Standard Controls ]================================================== -->
                    <TabViewItem Header="Standard Controls" IsClosable="False">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="AllApps"/>
                        </TabViewItem.IconSource>
                        <TabViewItem.Content>
                            <ScrollViewer VerticalScrollMode="Enabled" Padding="12">
                                <StackPanel Spacing="20">

                                    <!-- Buttons -->
                                    <TextBlock Text="Buttons" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Normal Button"/>
                                        <Button Content="Disabled" IsEnabled="False"/>
                                        <ToggleButton Content="Toggle (Off)"/>
                                        <ToggleButton Content="Toggle (On)" IsChecked="True"/>
                                        <DropDownButton Content="Dropdown">
                                            <DropDownButton.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Option One"/>
                                                    <MenuFlyoutItem Text="Option Two"/>
                                                    <MenuFlyoutSeparator/>
                                                    <MenuFlyoutItem Text="Option Three"/>
                                                </MenuFlyout>
                                            </DropDownButton.Flyout>
                                        </DropDownButton>
                                        <SplitButton Content="Split Action">
                                            <SplitButton.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Alt Action A"/>
                                                    <MenuFlyoutItem Text="Alt Action B"/>
                                                </MenuFlyout>
                                            </SplitButton.Flyout>
                                        </SplitButton>
                                    </StackPanel>

                                    <!-- Text Input -->
                                    <TextBlock Text="Text Input" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <StackPanel Spacing="6" MaxWidth="400" HorizontalAlignment="Left">
                                        <TextBox PlaceholderText="Normal TextBox"/>
                                        <TextBox PlaceholderText="Disabled TextBox" IsEnabled="False"/>
                                        <PasswordBox PlaceholderText="Password"/>
                                        <NumberBox PlaceholderText="NumberBox" SpinButtonPlacementMode="Compact" Value="42"/>
                                    </StackPanel>

                                    <!-- Selection -->
                                    <TextBlock Text="Selection" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Top">
                                        <StackPanel Spacing="4" Width="180">
                                            <TextBlock Text="ComboBox" FontStyle="Italic" Opacity="0.7"/>
                                            <ComboBox SelectedIndex="0" HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="Choice Alpha"/>
                                                <ComboBoxItem Content="Choice Beta"/>
                                                <ComboBoxItem Content="Choice Gamma"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Spacing="4" Width="180">
                                            <TextBlock Text="ListBox" FontStyle="Italic" Opacity="0.7"/>
                                            <ListBox SelectedIndex="1" Height="100">
                                                <ListBoxItem Content="Item One"/>
                                                <ListBoxItem Content="Item Two (selected)"/>
                                                <ListBoxItem Content="Item Three"/>
                                                <ListBoxItem Content="Item Four"/>
                                            </ListBox>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Checkboxes" FontStyle="Italic" Opacity="0.7"/>
                                            <CheckBox Content="Unchecked"/>
                                            <CheckBox Content="Checked" IsChecked="True"/>
                                            <CheckBox Content="Indeterminate" IsChecked="{x:Null}"/>
                                            <CheckBox Content="Disabled" IsEnabled="False"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="RadioButtons" FontStyle="Italic" Opacity="0.7"/>
                                            <RadioButton Content="Option A" GroupName="Demo" IsChecked="True"/>
                                            <RadioButton Content="Option B" GroupName="Demo"/>
                                            <RadioButton Content="Option C" GroupName="Demo"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Toggle -->
                                    <TextBlock Text="Toggle Switch" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <ToggleSwitch Header="Off state" IsOn="False"/>
                                        <ToggleSwitch Header="On state (AJut primary highlight)" IsOn="True"/>
                                        <ToggleSwitch Header="Disabled" IsEnabled="False"/>
                                    </StackPanel>

                                    <!-- Navigation / Expander -->
                                    <TextBlock Text="Expander" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <Expander Header="Section A - click to expand" HorizontalAlignment="Left" MinWidth="340">
                                        <StackPanel Padding="8" Spacing="4">
                                            <TextBlock Text="This is the AJut-themed Expander content area."/>
                                            <TextBlock Text="Background uses AJut_Brush_PanelBackground."/>
                                            <Button Content="A button inside the expander"/>
                                        </StackPanel>
                                    </Expander>
                                    <Expander Header="Section B - starts open" IsExpanded="True" HorizontalAlignment="Left" MinWidth="340">
                                        <TextBlock Text="Content visible on load." Padding="8"/>
                                    </Expander>

                                    <!-- Menu -->
                                    <TextBlock Text="MenuBar" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <MenuBar>
                                        <MenuBarItem Title="File">
                                            <MenuFlyoutItem Text="New"/>
                                            <MenuFlyoutItem Text="Open..."/>
                                            <MenuFlyoutItem Text="Save"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Exit"/>
                                        </MenuBarItem>
                                        <MenuBarItem Title="Edit">
                                            <MenuFlyoutItem Text="Undo"/>
                                            <MenuFlyoutItem Text="Redo"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Cut"/>
                                            <MenuFlyoutItem Text="Copy"/>
                                            <MenuFlyoutItem Text="Paste"/>
                                        </MenuBarItem>
                                        <MenuBarItem Title="View">
                                            <MenuFlyoutItem Text="Zoom In"/>
                                            <MenuFlyoutItem Text="Zoom Out"/>
                                        </MenuBarItem>
                                    </MenuBar>

                                </StackPanel>
                            </ScrollViewer>
                        </TabViewItem.Content>
                    </TabViewItem>

                    <!-- ===[ Toggle Controls ]================================================= -->
                    <TabViewItem Header="Toggle Controls" IsClosable="False">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="Switch"/>
                        </TabViewItem.IconSource>
                        <TabViewItem.Content>
                            <ScrollViewer VerticalScrollMode="Enabled" Padding="12">
                                <StackPanel Spacing="20">

                                    <TextBlock Text="ToggleSwitch" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="On state uses AJut primary highlight color." FontStyle="Italic" Opacity="0.7"/>
                                    <StackPanel Spacing="8">
                                        <ToggleSwitch Header="Feature A" IsOn="False" OnContent="Enabled" OffContent="Disabled"/>
                                        <ToggleSwitch Header="Feature B" IsOn="True" OnContent="Enabled" OffContent="Disabled"/>
                                        <ToggleSwitch Header="Feature C (disabled)" IsOn="True" IsEnabled="False" OnContent="Enabled" OffContent="Disabled"/>
                                        <ToggleSwitch Header="Feature D (disabled off)" IsOn="False" IsEnabled="False" OnContent="Enabled" OffContent="Disabled"/>
                                    </StackPanel>

                                    <TextBlock Text="ToggleButton" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="Checked state uses AJut_Brush_PrimaryHighlight background." FontStyle="Italic" Opacity="0.7"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ToggleButton Content="Bold" IsChecked="False"/>
                                        <ToggleButton Content="Italic" IsChecked="True"/>
                                        <ToggleButton Content="Underline" IsChecked="False"/>
                                        <ToggleButton Content="Strikethrough" IsChecked="True"/>
                                        <ToggleButton Content="Disabled (on)" IsChecked="True" IsEnabled="False"/>
                                    </StackPanel>

                                    <TextBlock Text="ToggleStrip" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="Single-select by default. AllowMultiSelect for multi-select, AllowNoSelection to permit zero selected." FontStyle="Italic" Opacity="0.7" TextWrapping="Wrap"/>
                                    <StackPanel Spacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Single-select (default)" FontSize="11" Opacity="0.7"/>
                                            <ajut:ToggleStrip x:Name="ToggleStripSingle"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Multi-select" FontSize="11" Opacity="0.7"/>
                                            <ajut:ToggleStrip x:Name="ToggleStripMulti" AllowMultiSelect="True"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Allow no selection" FontSize="11" Opacity="0.7"/>
                                            <ajut:ToggleStrip x:Name="ToggleStripFreeform" AllowNoSelection="True"/>
                                        </StackPanel>

                                        <!-- Bug repro: programmatic SelectedItem with boxed enum -->
                                        <StackPanel Spacing="4" Margin="0,12,0,0">
                                            <TextBlock Text="Programmatic SelectedItem (enum bug repro)" FontSize="11" Opacity="0.7"/>
                                            <TextBlock Text="Click the button to set SelectedItem to 'Number' programmatically. With the bug, it stays on 'Text'." TextWrapping="Wrap" FontSize="11" Opacity="0.5"/>
                                            <ajut:ToggleStrip x:Name="ToggleStripEnumBugRepro"
                                                              SelectedItem="{x:Bind SelectedEditorMode, Mode=TwoWay}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Set to Number" Click="EnumBugRepro_OnSetNumber"/>
                                                <Button Content="Set to Color" Click="EnumBugRepro_OnSetColor"/>
                                                <Button Content="Set to Text" Click="EnumBugRepro_OnSetText"/>
                                                <TextBlock x:Name="EnumBugReproStatus" VerticalAlignment="Center" Opacity="0.7"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                </StackPanel>
                            </ScrollViewer>
                        </TabViewItem.Content>
                    </TabViewItem>

                    <!-- ===[ Custom AJut Controls ]======================================== -->
                    <TabViewItem Header="Custom AJut Controls" IsClosable="False" VerticalContentAlignment="Stretch">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="Edit"/>
                        </TabViewItem.IconSource>
                        <TabViewItem.Content>
                            <ScrollViewer VerticalAlignment="Stretch" Padding="12">
                                <StackPanel Spacing="20" HorizontalAlignment="Left">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,3,0">
                                            <TextBlock Text="String to Brush Example" TextWrapping="WrapWholeWords"/>
                                            <TextBox x:Name="BackgroundMaker" PlaceholderText="Color - like #FFF or linear-gradient(#F00, #00F)"/>
                                            <RichTextBlock IsTextSelectionEnabled="True">
                                                <Paragraph>
                                                    <Run Text="Setting the text below to a color like " Foreground="{ThemeResource AJut_Brush_NormalText}"/>
                                                    <Run Text="#F0F" FontFamily="Consolas" Foreground="#A22"/>
                                                    <Run Text=" will set the swatch below. Try more advanced things like: " Foreground="{ThemeResource AJut_Brush_NormalText}"/>
                                                    <Run Text="radial-gradient(circle at 25% 90%, #FF0000, #0000FF)" FontFamily="Consolas" Foreground="#A22"/>
                                                    <Run Text=" or "/>
                                                    <Run Text="linear-gradient(76deg, #A22, #0000FF)" FontFamily="Consolas" Foreground="#A22"/>
                                                </Paragraph>
                                            </RichTextBlock>
                                            <!-- The swatch that shows the background made -->
                                            <Grid Width="200" Height="200"
                                                  Background="{Binding ElementName=BackgroundMaker, Path=Text, Converter={ajut_conv:ColorStringToBrushConverter}}"/>
                                        </StackPanel>
                                        <ajut:GridSplitter HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="1"/>
                                        <Grid Grid.Column="1" Margin="3,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>
                                            <TextBlock Margin="3,0" TextWrapping="WrapWholeWords" Text="This is the right side, and it shows the testing of a Grid Splitter (which WINUI doesn't have by default for some reason?)"/>
                                            <ajut:GridSplitter Thickness="5" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" />
                                            <TextBlock Grid.Row="1" Margin="3,0" TextWrapping="WrapWholeWords" Text="This is the right side, but the 'Bottom split'"/>
                                        </Grid>
                                    </Grid>

                                    <TextBlock Text="Theme Switcher" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <ajut:EnumComboBox SelectedItem="{x:Bind Path=Application.ThemeManager.ThemeConfiguration, Mode=TwoWay}"/>
                                    <TextBlock Text="Using theme management + EnumComboBox" FontStyle="Italic" Opacity="0.7"/>

                                    <TextBlock Text="GeometryButton" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <ajut:GeometryButton Content="Geometry Button" BackgroundGeometry="M 0,0 20,20 40,0 150,0 150,100 100,90 0,100 Z"
                                                         TraceThickness="1"/>

                                    <TextBlock Text="ColorEditIngressControl" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="Shows the color swatch with hover edit overlay and glossy cover." FontStyle="Italic" Opacity="0.7"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Solid red" FontSize="11" Opacity="0.7"/>
                                            <ajut:ColorEditIngressControl Width="60" Height="40" EditColor="#FF0000"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Blue" FontSize="11" Opacity="0.7"/>
                                            <ajut:ColorEditIngressControl Width="60" Height="40" EditColor="#0000CC"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Semi-transparent orange" FontSize="11" Opacity="0.7"/>
                                            <ajut:ColorEditIngressControl Width="60" Height="40" EditColor="{Binding ElementName=ColorText, Path=Text, Mode=TwoWay, Converter={ajut_conv:ColorStringToColorConverter}}"/>
                                            <TextBlock Text="(Color bound to text via converter)" FontSize="11" Opacity="0.7"/>
                                            <TextBox x:Name="ColorText"  Text="#C9DB733F"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Text="ToggleStrip" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <ajut:ToggleStrip x:Name="ToggleStripCustom"
                                                      CornerRadius="15"/>

                                    <TextBlock Text="PathSelectionControl" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="Browse button opens OS file/folder picker. Invalid paths show red border + warning icon." FontStyle="Italic" Opacity="0.7" TextWrapping="Wrap"/>
                                    <StackPanel Spacing="12" MaxWidth="500" HorizontalAlignment="Left">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="File picker (open)" FontSize="11" Opacity="0.7"/>
                                            <ajut:PathSelectionControl x:Name="PathPickFile"
                                                                       PathType="File"
                                                                       TextBoxHeight="22"
                                                                       UnsetTextPrompt="Select a file..."
                                                                       TreatEmptyPathAsInvalid="True"
                                                                       TreatNonExistentPathAsInvalid="True"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Folder picker" FontSize="11" Opacity="0.7"/>
                                            <ajut:PathSelectionControl x:Name="PathPickFolder"
                                                                       PathType="Folder"
                                                                       UnsetTextPrompt="Select a folder..."
                                                                       IsOpenInExplorerButtonAllowed="True"
                                                                       TreatNonExistentPathAsInvalid="True"
                                                                       TextBoxPadding="0"
                                                                       />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="File picker (save, validates extension)" FontSize="11" Opacity="0.7"/>
                                            <ajut:PathSelectionControl x:Name="PathPickSaveFile"
                                                                        PathType="File"
                                                                        FileDialogType="SaveFile"
                                                                        FileFilter="Text files (*.txt)|*.txt"
                                                                        UnsetTextPrompt="Save path..."/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Text="Color Parsing Example" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <local:ColorParseExample Width="200" Height="200" HorizontalAlignment="Left"/>

                                </StackPanel>
                            </ScrollViewer>
                        </TabViewItem.Content>
                    </TabViewItem>

                    <!-- ===[ NumericEditor ]=============================================== -->
                    <TabViewItem Header="NumericEditor" IsClosable="False">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="Calculator"/>
                        </TabViewItem.IconSource>
                        <TabViewItem.Content>
                            <ScrollViewer VerticalScrollMode="Enabled" Padding="12">
                                <StackPanel Spacing="16" MaxWidth="420" HorizontalAlignment="Left">
                                    <TextBlock Text="NumericEditor" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="Gradient background, Consolas font, rim-lighting border, focus highlight, AJut-themed spin buttons." FontStyle="Italic" Opacity="0.7" TextWrapping="Wrap"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Integer" VerticalAlignment="Center" Margin="0,4"/>
                                        <ajut:NumericEditor Grid.Row="0" Grid.Column="1" Value="42" Margin="0,4"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Float" VerticalAlignment="Center" Margin="0,4"/>
                                        <ajut:NumericEditor Grid.Row="1" Grid.Column="1" Value="3.14" Margin="0,4"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Double" VerticalAlignment="Center" Margin="0,4"/>
                                        <ajut:NumericEditor Grid.Row="2" Grid.Column="1" Value="2.71828" Margin="0,4"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Clamped (0-100)" VerticalAlignment="Center" Margin="0,4"/>
                                        <ajut:NumericEditor Grid.Row="3" Grid.Column="1" Value="50" Minimum="0" Maximum="100" Margin="0,4"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Step by 0.5" VerticalAlignment="Center" Margin="0,4"/>
                                        <ajut:NumericEditor Grid.Row="4" Grid.Column="1" Value="1.5" Nudge="0.5" Margin="0,4"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Override Labels" VerticalAlignment="Top" Margin="0,4"/>
                                        <StackPanel Grid.Row="5" Grid.Column="1">
                                            <ajut:NumericEditor Value="1.5" Nudge="0.5" Margin="0,4">
                                                <ajut:NumericEditor.LabelContent>
                                                    <TextBlock Text="X" Foreground="Red" FontWeight="Bold" Margin="5,0" VerticalAlignment="Center" FontSize="20" FontFamily="Segoe UI"/>
                                                </ajut:NumericEditor.LabelContent>
                                            </ajut:NumericEditor>
                                            <ajut:NumericEditor Value="1.5" Nudge="0.5" Margin="0,4">
                                                <ajut:NumericEditor.LabelContent>
                                                    <TextBlock Text="Y" Foreground="#5C3" FontWeight="Bold" Margin="5,0" VerticalAlignment="Center" FontSize="20" FontFamily="Segoe UI"/>
                                                </ajut:NumericEditor.LabelContent>
                                            </ajut:NumericEditor>
                                            <ajut:NumericEditor Value="1.5" Nudge="0.5" Margin="0,4">
                                                <ajut:NumericEditor.LabelContent>
                                                    <TextBlock Text="Z" Foreground="#38F" FontWeight="Bold" Margin="5,0" VerticalAlignment="Center" FontSize="20" FontFamily="Segoe UI"/>
                                                </ajut:NumericEditor.LabelContent>
                                            </ajut:NumericEditor>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabViewItem.Content>
                    </TabViewItem>

                    <!-- ===[ Flat Tree List ]====================================================== -->
                    <TabViewItem Header="Flat Tree List" IsClosable="False" VerticalContentAlignment="Stretch">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="List"/>
                        </TabViewItem.IconSource>
                        <TabViewItem.Content>
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="FlatTreeListControl - expand/collapse tree nodes, multi-level nesting" FontStyle="Italic" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Text="Selection indicator: 4px colored strip on the left edge (AJut signature selection style). Row background receives only a subtle tint." TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,8"/>
                                <ajut:FlatTreeListControl Grid.Row="2"
                                                          Root="{x:Bind TreeRoot}"
                                                          IncludeRoot="True"
                                                          StartItemsExpanded="True">
                                    <ajut:FlatTreeListControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Source.NodeName}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </ajut:FlatTreeListControl.ItemTemplate>
                                </ajut:FlatTreeListControl>
                            </Grid>
                        </TabViewItem.Content>
                    </TabViewItem>

                    <!-- ===[ FlatTree Drag/Drop ]=================================================== -->
                    <TabViewItem Header="FlatTree Drag/Drop" IsClosable="False">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="MoveToFolder"/>
                        </TabViewItem.IconSource>
                        <TabViewItem.Content>
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="FlatTreeListControl - Drag and Drop Reordering + SetSelection test" FontStyle="Italic" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Text="Drag items to reorder. X position determines target depth. Blue insertion line shows where item will land; dotted connector shows target parent." TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,8"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                    <Button Content="SetSelection: 3 scattered items" Click="SetSelectionScattered_OnClick"/>
                                    <Button Content="SetSelection: all descendants of Scenes" Click="SetSelectionScenesDescendants_OnClick"/>
                                    <Button Content="SetSelection: empty" Click="SetSelectionEmpty_OnClick"/>
                                    <TextBlock x:Name="SetSelectionStatus" VerticalAlignment="Center" Opacity="0.8"/>
                                </StackPanel>
                                <ajut:FlatTreeListControl Grid.Row="3"
                                                          x:Name="DragDropTree"
                                                          Root="{x:Bind DragDropTreeRoot}"
                                                          IncludeRoot="True"
                                                          StartItemsExpanded="True"
                                                          IsDragDropReorderEnabled="True"
                                                          SelectionMode="Extended"
                                                          SelectionChanged="DragDropTree_OnSelectionChanged">
                                    <ajut:FlatTreeListControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Source.NodeName}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </ajut:FlatTreeListControl.ItemTemplate>
                                </ajut:FlatTreeListControl>
                            </Grid>
                        </TabViewItem.Content>
                    </TabViewItem>

                    <!-- ===[ PopupMenuButton ]===================================================== -->
                    <TabViewItem Header="PopupMenuButton" IsClosable="False">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="List"/>
                        </TabViewItem.IconSource>
                        <TabViewItem.Content>
                            <ScrollViewer VerticalScrollMode="Enabled" Padding="12">
                                <StackPanel Spacing="20" HorizontalAlignment="Left">
                                    <TextBlock Text="PopupMenuButton" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="A ToggleButton that opens a MenuFlyout. Button stays 'checked' (accent) while flyout is open."
                                               FontStyle="Italic" Opacity="0.7" TextWrapping="Wrap"/>

                                    <StackPanel Spacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Simple menu" FontSize="11" Opacity="0.7"/>
                                            <ajut:PopupMenuButton>
                                                <ajut:PopupMenuButton.ButtonContent>
                                                    <TextBlock Text="Actions" VerticalAlignment="Center"/>
                                                </ajut:PopupMenuButton.ButtonContent>
                                                <ajut:PopupMenuButton.MenuItems>
                                                    <MenuFlyoutItem Text="New File"/>
                                                    <MenuFlyoutItem Text="Open..."/>
                                                    <MenuFlyoutSeparator/>
                                                    <MenuFlyoutItem Text="Exit"/>
                                                </ajut:PopupMenuButton.MenuItems>
                                            </ajut:PopupMenuButton>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Edit menu" FontSize="11" Opacity="0.7"/>
                                            <ajut:PopupMenuButton>
                                                <ajut:PopupMenuButton.ButtonContent>
                                                    <TextBlock Text="Edit" VerticalAlignment="Center"/>
                                                </ajut:PopupMenuButton.ButtonContent>
                                                <ajut:PopupMenuButton.MenuItems>
                                                    <MenuFlyoutItem Text="Cut"/>
                                                    <MenuFlyoutItem Text="Copy"/>
                                                    <MenuFlyoutItem Text="Paste"/>
                                                    <MenuFlyoutSeparator/>
                                                    <MenuFlyoutItem Text="Select All"/>
                                                </ajut:PopupMenuButton.MenuItems>
                                            </ajut:PopupMenuButton>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabViewItem.Content>
                    </TabViewItem>

                    <!-- ===[ Property Grid ]======================================================= -->
                    <TabViewItem Header="Property Grid" IsClosable="False" VerticalContentAlignment="Stretch">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="View"/>
                        </TabViewItem.IconSource>
                        <TabViewItem.Content>
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>

                                <!-- Source switcher: simulates selecting different element types -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                            Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                    <TextBlock Text="Source:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Button x:Name="PG_AlphaButton" Content="Alpha (5 props, includes string+bool)"
                                            Click="PGSource_OnAlphaClicked"/>
                                    <Button x:Name="PG_BetaButton" Content="Beta (2 props, floats only)"
                                            Click="PGSource_OnBetaClicked"/>
                                    <Button x:Name="PG_ComplexButton" Content="Complex (ShowRoomTester)"
                                            Click="PGSource_OnComplexClicked"/>
                                    <Button Content="Set Elevated Values" Click="PGSource_OnSetElevatedClicked"
                                            ToolTipService.ToolTip="Sets elevated property values externally - tests RecacheEditValue cascade"/>
                                    <Button x:Name="PG_WrappedMatrixButton" Content="Wrapped Mode Matrix (PGShowIf repro)"
                                            Click="PGSource_OnWrappedMatrixClicked"
                                            ToolTipService.ToolTip="Source whose Mode is behind a wrapper; rows A/B/C conditional on Mode.Value"/>
                                    <Button x:Name="PG_NoneButton" Content="None (Empty)"
                                            Click="PGSource_OnNoneClicked"/>
                                </StackPanel>

                                <!-- Mode cycler for the Wrapped Mode Matrix source. Directly mutates
                                     the wrapper's Value so the only signal is the wrapper's INPC. -->
                                <StackPanel Grid.Row="1" Grid.Column="0"
                                            Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                    <TextBlock Text="Matrix Mode:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Button Content="Mode -> A" Click="PGMatrix_SetModeA"/>
                                    <Button Content="Mode -> B" Click="PGMatrix_SetModeB"/>
                                    <Button Content="Mode -> C" Click="PGMatrix_SetModeC"/>
                                    <TextBlock x:Name="PGMatrixDiagnostic"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="11"
                                               Text="(diagnostics will appear here after clicking a Mode button)"/>
                                </StackPanel>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="PropertyGrid - switch sources above to test live refresh" FontStyle="Italic" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Live source object (JSON)" FontStyle="Italic" Margin="0,0,0,8"/>

                                <!-- SingleItemSource set in code-behind so we can swap it via the buttons above -->
                                <ajut:PropertyGrid x:Name="TestPropertyGrid"
                                                   Grid.Row="3" Grid.Column="0"
                                                   RowSpacing="5"
                                                   FixedRowHeight="40"
                                                   LabelColumnWidth="180">
                                    <ajut:PropertyGrid.ItemTemplateSelector>
                                        <ajut:PropertyGridTemplateSelector>
                                            <ajut:PropertyGridTemplateSelector.Default>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Path=EditValue}" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </ajut:PropertyGridTemplateSelector.Default>
                                            <ajut:PropertyGridTemplateSelector.RegisteredTemplates>
                                                <DataTemplate x:Key="Single" x:DataType="ajut_pg:PropertyEditTarget">
                                                    <ajut:NumericEditor Value="{Binding Path=EditValue, Mode=TwoWay}" TextBoxHeight="20"
                                                                        Minimum="{Binding Path=EditContext.Min, Mode=TwoWay, FallbackValue=-10000}"
                                                                        Maximum="{Binding Path=EditContext.Max, Mode=TwoWay, FallbackValue=10000}"
                                                                        BigNudge="{Binding Path=EditContext.BigStep, Mode=OneWay, FallbackValue=5}"
                                                                        Nudge="{Binding Path=EditContext.Step, Mode=OneWay, FallbackValue=1}"
                                                                        SmallNudge="{Binding Path=EditContext.SmallStep, Mode=OneWay, FallbackValue=0.1}"/>
                                                </DataTemplate>
                                                <DataTemplate x:Key="Double">
                                                    <ajut:NumericEditor Value="{Binding Path=EditValue, Mode=TwoWay}" TextBoxHeight="20"/>
                                                </DataTemplate>
                                                <DataTemplate x:Key="Int32">
                                                    <ajut:NumericEditor Value="{Binding Path=EditValue, Mode=TwoWay}" TextBoxHeight="20"/>
                                                </DataTemplate>
                                                <DataTemplate x:Key="ColorPick">
                                                    <ajut:ColorEditIngressControl EditColor="{Binding Path=EditValue, Mode=TwoWay}" VerticalAlignment="Stretch" MaxWidth="150" HorizontalAlignment="Left"/>
                                                </DataTemplate>
                                                <DataTemplate x:Key="Boolean">
                                                    <CheckBox IsChecked="{Binding Path=EditValue, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                                <DataTemplate x:Key="String">
                                                    <TextBox Text="{Binding Path=EditValue, Mode=TwoWay}"/>
                                                </DataTemplate>
                                                <DataTemplate x:Key="eEditorMode">
                                                    <ajut:EnumComboBox SelectedItem="{Binding Path=EditValue, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                                <DataTemplate x:Key="SpecialString">
                                                    <Border CornerRadius="8" Padding="3" Background="Yellow"
                                                            ToolTipService.ToolTip="This shows usage of elevate as parent, where property attributes were deffered back to parent">
                                                        <TextBox Text="{Binding Path=EditValue, Mode=TwoWay}"/>
                                                    </Border>
                                                </DataTemplate>
                                                <DataTemplate x:Key="WidgetEditor">
                                                    <Border>
                                                        <StackPanel>
                                                            <TextBlock Text="Widget Editor:"/>
                                                            <ajut:NumericEditor Value="{Binding Path=EditValue.SubObjValue, Mode=TwoWay}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ajut:PropertyGridTemplateSelector.RegisteredTemplates>
                                        </ajut:PropertyGridTemplateSelector>
                                    </ajut:PropertyGrid.ItemTemplateSelector>
                                </ajut:PropertyGrid>

                                <!-- JSON display: live mirror of current source, updated on every PropertyTreeChanged -->
                                <Border Grid.Row="3" Grid.Column="2"
                                        BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="PropertyGridJsonDisplay"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   Margin="6"
                                                   TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </TabViewItem.Content>
                    </TabViewItem>

                    <!-- ===[ Dock Zone ]=========================================================== -->
                    <TabViewItem Header="Dock Zone" IsClosable="False" VerticalContentAlignment="Stretch">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="DockLeft"/>
                        </TabViewItem.IconSource>
                        <TabViewItem.Content>
                            <Grid Loaded="DockZoneTab_OnLoaded">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="4,4,4,4">
                                    <Button Content="Save Layout" Click="DockZone_OnSaveLayoutClicked"/>
                                    <Button Content="Load Layout" Click="DockZone_OnLoadLayoutClicked"/>
                                    <Button Content="Set All Values (test)" Click="DockZone_OnSetAllValuesTestClicked"/>
                                    <MenuBar>
                                        <MenuBarItem x:Name="ViewMenu" Title="View" />
                                    </MenuBar>
                                </StackPanel>
                                <ajut:DockPanelAddRemoveToolbar x:Name="DockToolbar" Grid.Row="1"/>
                                <ajut:DockZone x:Name="TestDockZone" Grid.Row="2" Margin="5"/>
                            </Grid>
                        </TabViewItem.Content>
                    </TabViewItem>

                </TabView>
            </Border>
        </Grid>
    </ajut:ThemedWindowRootControl>
</Window>
