<Page
    x:Class="AJutShowRoomWinUI.UseCaseTest.UseCaseLandingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="16" VerticalScrollMode="Enabled">
        <StackPanel Spacing="14" MaxWidth="780" HorizontalAlignment="Left">
            <TextBlock Text="Use-Case Leak Test" Style="{ThemeResource TitleTextBlockStyle}"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.85"
                       Text="This page navigates (by type, no page caching) to an editor built the way a real tool editor is: a docking experience whose panels are a flat tree of tools and a property grid, both bound to a long-lived document model. The document outlives the editor, the way a real app's project/document outlives the views opened on it."/>
            <TextBlock TextWrapping="Wrap" Opacity="0.85"
                       Text="Open the editor, edit a tool, then come back (the editor's Back button); repeat a few cycles, then run the probe. By default the editor uses NAIVE teardown - it disposes the docking manager but otherwise just drops the page, the way a typical consumer leaves an editor. The probe forces GC and reports whether the editor graph collected. A FAIL means the long-lived document is still pinning dropped editors - a framework teardown gap (the document itself is expected to stay alive). Toggle 'Careful teardown' in the editor to confirm the difference."/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Open Editor" Click="OnOpenEditorClicked"/>
                <Button Content="Run Memory Leak Probe" Click="OnRunProbeClicked"/>
                <Button Content="Reset Probe History" Click="OnResetProbeClicked"/>
            </StackPanel>
            <TextBox x:Name="ProbeOutput"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="200"
                     FontFamily="Consolas"
                     FontSize="12"
                     PlaceholderText="Probe results appear here (newest first)."/>
        </StackPanel>
    </ScrollViewer>
</Page>
