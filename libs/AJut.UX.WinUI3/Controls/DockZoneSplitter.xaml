<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <Style TargetType="local:DockZoneSplitter">
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:DockZoneSplitter">
                    <!-- Transparent background is required for pointer hit-testing in WinUI3 -->
                    <Grid Background="Transparent">
                        <!-- Subtle 1px visual stripe centered in the splitter area -->
                        <Rectangle Fill="#18000000"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Stretch"
                                   Width="1"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
