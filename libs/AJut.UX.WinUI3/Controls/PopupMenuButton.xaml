<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <!-- ===[ PopupMenuButton ]=== -->
    <!-- Default style: system resources only, no AJut_ keys.
         A ToggleButton (PART_Button) shows the button content + dropdown arrow glyph.
         The ToggleButton's Checked/Unchecked visual state reflects the flyout open state -
         when the flyout is open the button appears "pressed/checked" (accent background).
         AllControlThemeOverrides.xaml can override Background/BorderBrush via a Style setter
         without needing to duplicate the template. -->
    <Style TargetType="local:PopupMenuButton">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PopupMenuButton">
                    <ToggleButton x:Name="PART_Button"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  Padding="{TemplateBinding Padding}"
                                  HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                  CornerRadius="2">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <!-- Caller-supplied button content -->
                            <ContentControl Content="{TemplateBinding ButtonContent}"
                                            ContentTemplate="{TemplateBinding ButtonContentTemplate}"
                                            IsTabStop="False"
                                            VerticalAlignment="Center"/>
                            <!-- Dropdown chevron glyph -->
                            <FontIcon Glyph="&#xE972;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="9"
                                      Foreground="{ThemeResource AJut_PopupMenuButton_ChevronForeground}"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
