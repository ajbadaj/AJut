<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <!-- ===========[ DockLeafLayout: Default Style ]========================= -->
    <!-- 3-row leaf layout used by DockZone for Single and Tabbed orientations.
         Visual properties live in the Style Setters below (override per-theme without
         redefining the Template).  TemplateBinding handles most brush/radius props;
         IsTabbed-dependent BorderThickness suppression is handled in code.

         Tab overlap: PART_TabStripWrapper sits in row 2.  The selected DockTabItem
         uses Margin="0,-2,0,0" in its Selected VSM state to bleed slightly into the
         content area, giving the appearance the tab connects to the content panel.
         Grid children are not clipped, so negative margins render correctly. -->

    <Style TargetType="local:DockLeafLayout">
        <Setter Property="HorizontalAlignment"  Value="Stretch"/>
        <Setter Property="VerticalAlignment"    Value="Stretch"/>
        <Setter Property="IsTabStop"            Value="False"/>
        <Setter Property="UseSystemFocusVisuals" Value="False"/>

        <!-- Default colors — override in a theme Style (no template redefinition needed) -->
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="#FFF0F0F0"/></Setter.Value>
        </Setter>
        <Setter Property="PanelBackground">
            <Setter.Value><SolidColorBrush Color="#FF2B2B2B"/></Setter.Value>
        </Setter>
        <Setter Property="PanelBorderBrush">
            <Setter.Value><SolidColorBrush Color="#FF4A4A4A"/></Setter.Value>
        </Setter>
        <Setter Property="PanelBorderThickness" Value="1"/>
        <Setter Property="PanelCornerRadius"    Value="0"/>
        <Setter Property="TabStripBackground">
            <Setter.Value><SolidColorBrush Color="#FF1A1A1A"/></Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:DockLeafLayout">
                    <Grid UseLayoutRounding="True">
                        <Grid.RowDefinitions>
                            <!-- Row 0: header bar (panel title + optional close button) -->
                            <RowDefinition Height="Auto"/>
                            <!-- Row 1: content panel -->
                            <RowDefinition Height="*"/>
                            <!-- Row 2: tab strip (Auto height; collapsed when not tabbed) -->
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Header bar -->
                        <Border x:Name="PART_HeaderBar"
                                Grid.Row="0"
                                Background="{TemplateBinding PanelBackground}"
                                BorderBrush="{TemplateBinding PanelBorderBrush}"
                                BorderThickness="1"
                                Margin="0,0,0,-2"
                                UseLayoutRounding="True"/>

                        <!-- Row 1: Content panel.
                             Background / BorderBrush / BorderThickness / CornerRadius /
                             Padding all pushed from code.  Bottom border is suppressed
                             when IsTabbed=true so the tab strip's top border provides
                             the sole visual boundary at that edge. -->
                        <Border x:Name="PART_ContentBorder"
                                Grid.Row="1"
                                Padding="2"
                                BorderThickness="1"
                                CornerRadius="0"
                                Background="{TemplateBinding PanelBackground}"
                                BorderBrush="{TemplateBinding PanelBorderBrush}"
                                UseLayoutRounding="True">
                            <ContentPresenter x:Name="PART_ContentPresenter"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Border>

                        <!-- Row 2: Tab strip.
                             Margin="0,-1,0,0": pulls the strip 1px up so its top border
                             sits exactly at the content panel's bottom edge.  The outer
                             Grid does not clip, so the -1px offset renders correctly.
                             BorderThickness="0,1,0,0": the 1px top border is the only
                             visual separation between content and tabs.
                             Visibility is toggled by ApplyTabbedState() in code. -->
                        <Border x:Name="PART_TabStripWrapper"
                                Grid.Row="2"
                                Margin="5,-1.5,5,5"
                                BorderThickness="0,0,0,0"
                                Padding="2,0,2,2"
                                Background="Transparent"
                                Visibility="Collapsed"
                                Height="28"
                                UseLayoutRounding="True">
                            <ContentPresenter x:Name="PART_TabNavPresenter"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
