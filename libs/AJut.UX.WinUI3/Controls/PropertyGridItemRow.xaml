<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls"
                    xmlns:conv="using:AJut.UX.Converters">

    <!-- ===[ PropertyGridItemRow ]=== -->
    <!-- Per-property row presenter for PropertyGrid.
         DataContext = FlatTreeItem (set by ListView/FlatTreeListControl).
         Binds to FlatTreeItem.Source.* for property display name, editor target, etc.
         PART_LabelBorder width is set in code based on LabelColumnWidth and IndentWidth.

         Selection visual: a 4px left nub + 1px top/right/bottom outline on PART_LabelBorder.
         Only the BorderBrush changes (BorderThickness is always 4,1,1,1), no layout jitter.
         Hover visual: a subtle full-row tint via PART_HoverBorder (separate VSM group,
         does not conflict with the label-only selection indicator).

         Label template: PART_LabelContent.ContentTemplate switches between
         DefaultValueLabelDataTemplate (value at default) and ModifiedValueLabelDataTemplate
         (value changed) based on PropertyEditTarget.IsAtDefaultValue, managed in code.
         Right-tapping PART_LabelBorder shows a context menu with "Set to default". -->

    <conv:BooleanToVisibilityConverter x:Key="PGItemRow_BoolToVis"
                                       TrueValue="Visible"
                                       FalseValue="Collapsed"/>

    <Style TargetType="local:PropertyGridItemRow">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PropertyGridItemRow">
                    <Grid x:Name="PART_Root"
                          HorizontalAlignment="Stretch">

                        <!-- Full-row hover tint. Background + BorderBrush driven by HoverStates VSM group.
                             Selection is indicated on PART_LabelBorder only (label column).
                             BorderThickness="1" is permanent so the reserved space never causes
                             layout jitter when the border appears/disappears. -->
                        <Border x:Name="PART_HoverBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                IsHitTestVisible="False"/>

                        <!-- Content (label + editor) inset by Padding (set from PropertyGrid.ElementPadding). -->
                        <Grid x:Name="PART_ContentGrid"
                              Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <!-- Column 0: label - width managed in code via PART_LabelBorder.Width -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Column 1: editor fills the rest -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Label area: width set in code via ApplyLabelColumnWidth().
                                 BorderThickness="4,1,1,1" permanently reserves space for the
                                 4px left nub + 1px outline so content never shifts; only
                                 BorderBrush changes via VSM (Transparent <-> SelectionBrush).
                                 Selection stays confined to the label column.
                                 Right-tapping this border triggers the "Set to default" context menu. -->
                            <Border x:Name="PART_LabelBorder"
                                    Grid.Column="0"
                                    MinWidth="80"
                                    Margin="0,0,3,0"
                                    BorderBrush="Transparent"
                                    BorderThickness="4,1,1,1"
                                    Background="Transparent">
                                <StackPanel VerticalAlignment="Center">
                                    <!-- PART_LabelContent: ContentTemplate switches between
                                         DefaultValueLabelDataTemplate and ModifiedValueLabelDataTemplate
                                         based on PropertyEditTarget.IsAtDefaultValue (set in code).
                                         Content = PropertyEditTarget (FlatTreeItem.Source). -->
                                    <ContentControl x:Name="PART_LabelContent"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    Content="{Binding Source}"/>
                                    <!-- PART_SubtitleText: shown below the label when PropertyEditTarget.Subtitle
                                         is set. Text, Visibility, and Style are applied in code. -->
                                    <TextBlock x:Name="PART_SubtitleText"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- Editor: Content is set from code (PropertyGridItemRow.ApplyEditorContent)
                                 rather than via a XAML binding. A binding on Content fights the
                                 DataContext-propagation timing: when the row's DataContext switches
                                 to a new FlatTreeItem the binding re-evaluates against the stale
                                 FlatTreeItem and overrides any programmatic Content set we do in
                                 OnDataContextChanged. By owning Content in code we guarantee the
                                 editor always shows the correct PropertyEditTarget.
                                 Hidden when IsExpandable=true with no elevation (no inline editor). -->
                            <ContentControl x:Name="PART_EditorContent"
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding Source.HasInlineEditor, Converter={StaticResource PGItemRow_BoolToVis}}"
                                            ContentTemplateSelector="{TemplateBinding EditorTemplateSelector}"/>
                        </Grid>

                        <VisualStateManager.VisualStateGroups>
                            <!-- HoverStates: full-row background tint + border, independent of selection. -->
                            <VisualStateGroup x:Name="HoverStates">
                                <VisualState x:Name="NotHovered"/>
                                <VisualState x:Name="Hovered">
                                    <VisualState.Setters>
                                        <Setter Target="PART_HoverBorder.Background"
                                                Value="{ThemeResource AJut_PropertyGridItemRow_HoverBackground}"/>
                                        <Setter Target="PART_HoverBorder.BorderBrush"
                                                Value="{ThemeResource AJut_PropertyGridItemRow_HoverBorderBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <!-- SelectionStates: bright nub + outline on label border only.
                                 Only BorderBrush changes - BorderThickness is always 4,1,1,1. -->
                            <VisualStateGroup x:Name="SelectionStates">
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="PART_LabelBorder.BorderBrush" Value="Transparent"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Target="PART_LabelBorder.BorderBrush"
                                                Value="{ThemeResource AJut_PropertyGridItemRow_SelectionBorderBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
