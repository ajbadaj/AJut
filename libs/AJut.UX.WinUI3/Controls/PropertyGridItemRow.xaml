<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <!-- ===[ PropertyGridItemRow ]=== -->
    <!-- Per-property row presenter for PropertyGrid.
         DataContext = PropertyEditTarget, set by ListView.
         EditorTemplateSelector is pushed from PropertyGrid via ContainerContentChanging,
         then forwarded to ContentControl.ContentTemplateSelector via TemplateBinding.
         This is the WinUI3 workaround for WPF's RelativeSource AncestorType binding
         (unavailable in WinUI3 DataTemplate contexts). -->
    <Style TargetType="local:PropertyGridItemRow">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PropertyGridItemRow">
                    <Grid HorizontalAlignment="Stretch"
                          Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding DisplayName}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontStyle="Italic"
                                   Opacity="0.8"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTipService.ToolTip="{Binding DisplayName}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <!-- Content = PropertyEditTarget; selector picks editor template
                             based on PropertyEditTarget.Editor (type name or [PGEditor]). -->
                        <ContentControl Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Content="{Binding}"
                                        ContentTemplateSelector="{TemplateBinding EditorTemplateSelector}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
