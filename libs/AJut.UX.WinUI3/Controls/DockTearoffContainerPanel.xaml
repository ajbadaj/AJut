<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <!-- ===========[ DockTearoffContainerPanel: Default Style ]================ -->
    <!-- Window content for DockingManager tearoff windows. Two-row layout:
         row 0 = custom title bar (stacked-windows icon + title + decorative lines +
                 maximize/restore button + close button),
         row 1 = the DockZone.

         All visual brush properties reference flat ThemeResource keys defined in
         AJutCustomControlStylingDefaults.xaml (Generic.xaml). AJutThemeMapAliasing.xaml
         (merged flat into AllControlThemeOverrides.xaml / App.Resources) overrides them
         with AJut-themed values when the theme is loaded.

         PART_TitleBarArea is the drag-sensitive region; pointer events on it are
         handled in code-behind. PART_MaximizeRestoreButton and PART_CloseButton sit in
         their own columns and capture pointer events before they bubble to the Grid,
         preventing accidental drag initiation on button clicks.

         PART_CloseButton uses an inline ControlTemplate that mirrors TitleBarCaptionButton's
         default template with PointerOver changed to the red chrome-close hover brush.
         VSM Setters own Background/Foreground; no TemplateBinding conflicts.

         PART_TitleText.Text is pushed from code-behind (ApplyTitle) in both OnApplyTemplate
         (data-before-template) and the Title DP change handler (template-before-data),
         working around WinUI3 TemplateBinding backfill limitations. -->

    <Style TargetType="local:DockTearoffContainerPanel">
        <Setter Property="HorizontalAlignment"   Value="Stretch"/>
        <Setter Property="VerticalAlignment"     Value="Stretch"/>
        <Setter Property="IsTabStop"             Value="False"/>
        <Setter Property="UseSystemFocusVisuals" Value="False"/>
        <Setter Property="TitleBarHeight"        Value="32"/>
        <Setter Property="TitleBarBackground"    Value="{ThemeResource AJut_DockTearoffContainerPanel_TitleBarBackground}"/>
        <Setter Property="TitleBarForeground"    Value="{ThemeResource AJut_DockTearoffContainerPanel_TitleBarForeground}"/>

        <!-- ApplicationPageBackgroundThemeBrush is the standard WinUI3 page background.
             AllControlThemeOverrides.xaml overrides this with AJut_Brush_PanelBackground
             when the AJut theme is loaded. Using a built-in ThemeResource here ensures
             the panel always has a non-transparent background even without the AJut theme. -->
        <Setter Property="Background" Value="{ThemeResource ApplicationPageBackgroundThemeBrush}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:DockTearoffContainerPanel">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Title bar.
                             The outer Grid is PART_TitleBarArea and receives drag pointer events
                             in code-behind. Caption buttons capture pointer events in columns 2
                             and 3 before they bubble to the Grid, so button clicks never start
                             a drag. The title bar has four columns:
                               0 = stacked-windows icon (Viewbox + Path)
                               1 = title TextBlock flanked by semi-transparent decorative lines
                               2 = PART_MaximizeRestoreButton (TitleBarCaptionButton, default style)
                               3 = PART_CloseButton (TitleBarCaptionButton, red hover) -->
                        <Grid x:Name="PART_TitleBarArea"
                              Grid.Row="0"
                              Height="{TemplateBinding TitleBarHeight}"
                              Background="{TemplateBinding TitleBarBackground}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>   <!-- icon -->
                                <ColumnDefinition Width="*"/>      <!-- title + decorative lines -->
                                <ColumnDefinition Width="Auto"/>   <!-- maximize/restore -->
                                <ColumnDefinition Width="Auto"/>   <!-- close -->
                            </Grid.ColumnDefinitions>

                            <!-- Column 0: Stacked-windows icon (two overlapping rectangles).
                                 Path data: bottom rect (0,4)→(12,4)→(12,12)→(0,12), top rect
                                 (4,0)→(16,0)→(16,8)→(4,8). Viewbox scales to 14×14 logical px. -->
                            <Viewbox Grid.Column="0"
                                     Width="14" Height="14"
                                     Margin="8,0,4,0"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Data="M 0,4 H 12 V 12 H 0 Z M 4,0 H 16 V 8 H 4 Z"
                                      Stroke="{TemplateBinding TitleBarForeground}"
                                      StrokeThickness="1.5"
                                      Fill="Transparent"/>
                            </Viewbox>

                            <!-- Column 1: Title text flanked by three stacked decorative lines on each side.
                                 Three sub-columns: [lines * | PART_TitleText Auto | lines *].
                                 Each side is a vertical StackPanel of 3 thin Rectangles (Spacing=3)
                                 at Opacity="0.3" to appear as subtle separators.
                                 PART_TitleText.Text is set by code-behind (ApplyTitle). -->
                            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Stretch"
                                            Spacing="3">
                                    <Rectangle Height="1" HorizontalAlignment="Stretch"
                                               Fill="{TemplateBinding TitleBarForeground}" Opacity="0.3"/>
                                    <Rectangle Height="1" HorizontalAlignment="Stretch"
                                               Fill="{TemplateBinding TitleBarForeground}" Opacity="0.3"/>
                                    <Rectangle Height="1" HorizontalAlignment="Stretch"
                                               Fill="{TemplateBinding TitleBarForeground}" Opacity="0.3"/>
                                </StackPanel>
                                <TextBlock x:Name="PART_TitleText"
                                           Grid.Column="1"
                                           Foreground="{TemplateBinding TitleBarForeground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Margin="8,0"/>
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Stretch"
                                            Spacing="3">
                                    <Rectangle Height="1" HorizontalAlignment="Stretch"
                                               Fill="{TemplateBinding TitleBarForeground}" Opacity="0.3"/>
                                    <Rectangle Height="1" HorizontalAlignment="Stretch"
                                               Fill="{TemplateBinding TitleBarForeground}" Opacity="0.3"/>
                                    <Rectangle Height="1" HorizontalAlignment="Stretch"
                                               Fill="{TemplateBinding TitleBarForeground}" Opacity="0.3"/>
                                </StackPanel>
                            </Grid>

                            <!-- Column 2: Maximize/Restore button.
                                 Content (maximize or restore glyph) is set by code-behind via
                                 UpdateMaximizeRestoreGlyph. SetupForWindow wires window-activation
                                 tracking. FontSize="10" overrides the default Style Setter (16) so
                                 the glyph matches the close button size. -->
                            <local:TitleBarCaptionButton x:Name="PART_MaximizeRestoreButton"
                                                         Grid.Column="2"
                                                         FontSize="10"/>

                            <!-- Column 3: Close button with red chrome-close hover.
                                 Inline ControlTemplate mirrors TitleBarCaptionButton's default
                                 template with PointerOver changed to the red hover brush.
                                 Content (ChromeClose glyph E8BB) is fixed in XAML.
                                 SetupForWindow wires window-activation tracking. -->
                            <local:TitleBarCaptionButton x:Name="PART_CloseButton"
                                                         Grid.Column="3"
                                                         Content="&#xE8BB;">
                                <local:TitleBarCaptionButton.Style>
                                    <Style TargetType="local:TitleBarCaptionButton">
                                        <Setter Property="BorderBrush"       Value="Transparent"/>
                                        <Setter Property="BorderThickness"   Value="0"/>
                                        <Setter Property="Padding"           Value="0"/>
                                        <Setter Property="Width"             Value="48"/>
                                        <Setter Property="Height"            Value="32"/>
                                        <Setter Property="FontSize"          Value="10"/>
                                        <Setter Property="FontWeight"        Value="Normal"/>
                                        <Setter Property="CornerRadius"      Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="local:TitleBarCaptionButton">
                                                    <Grid x:Name="RootGrid">
                                                        <VisualStateManager.VisualStateGroups>
                                                            <VisualStateGroup x:Name="CommonStates">
                                                                <VisualState x:Name="Normal">
                                                                    <VisualState.Setters>
                                                                        <Setter Target="RootGrid.Background" Value="{ThemeResource WindowCaptionBackground}"/>
                                                                        <Setter Target="Presenter.Foreground" Value="{ThemeResource WindowCaptionForeground}"/>
                                                                    </VisualState.Setters>
                                                                </VisualState>
                                                                <VisualState x:Name="PointerOver">
                                                                    <VisualState.Setters>
                                                                        <Setter Target="RootGrid.Background" Value="{ThemeResource AJut_DockTearoffContainerPanel_CloseButtonHoverBackground}"/>
                                                                        <Setter Target="Presenter.Foreground" Value="{ThemeResource WindowCaptionForeground}"/>
                                                                    </VisualState.Setters>
                                                                </VisualState>
                                                                <VisualState x:Name="Pressed">
                                                                    <VisualState.Setters>
                                                                        <Setter Target="RootGrid.Background" Value="{ThemeResource AJut_DockTearoffContainerPanel_CloseButtonPressedBackground}"/>
                                                                        <Setter Target="Presenter.Foreground" Value="{ThemeResource WindowCaptionButtonStrokePressed}"/>
                                                                    </VisualState.Setters>
                                                                </VisualState>
                                                                <VisualState x:Name="Inactive">
                                                                    <VisualState.Setters>
                                                                        <Setter Target="Presenter.Foreground" Value="{ThemeResource TitleBarCaptionButtonInactiveForegroundColor}"/>
                                                                    </VisualState.Setters>
                                                                </VisualState>
                                                            </VisualStateGroup>
                                                        </VisualStateManager.VisualStateGroups>
                                                        <ContentPresenter x:Name="Presenter"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Content="{TemplateBinding Content}"
                                                                          FontFamily="Segoe MDL2 Assets"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </local:TitleBarCaptionButton.Style>
                            </local:TitleBarCaptionButton>
                        </Grid>

                        <!-- Row 1: DockZone presenter.
                             Content is pushed from code-behind in both OnApplyTemplate
                             (data-before-template) and the DockZoneContent DP handler
                             (template-before-data), working around WinUI3 TemplateBinding
                             backfill limitations. -->
                        <ContentPresenter x:Name="PART_ZonePresenter"
                                          Grid.Row="1"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
