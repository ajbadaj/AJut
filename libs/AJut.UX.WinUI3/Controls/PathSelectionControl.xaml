<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <!-- ===[ PathSelectionControl ]=== -->
    <!-- Default style: WinUI3 system resources only, no AJut_ brush keys.
         AllControlThemeOverrides.xaml provides the AJut-branded variant.
         Template parts: PART_Root, PART_PathTextBox, PART_BrowseButton,
         PART_ShowInExplorerButton (optional, collapsed unless IsOpenInExplorerButtonAllowed).
         VSM groups: BorderStates (Normal/Focused/PathInvalid),
                     WarningDisplayStates (WarningHidden/WarningShown),
                     ExplorerButtonStates (ExplorerButtonHidden/ExplorerButtonShown). -->
    <Style TargetType="local:PathSelectionControl">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="{ThemeResource TextControlBackground}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource TextControlBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1,1,1,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PathSelectionControl">
                    <Border x:Name="PART_Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0,3,3,0"
                            ToolTipService.ToolTip="{TemplateBinding SelectedPath}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Path entry TextBox -->
                            <TextBox x:Name="PART_PathTextBox"
                                     Grid.Column="0"
                                     PlaceholderText="{TemplateBinding UnsetTextPrompt}"
                                     FontFamily="Consolas"
                                     TextWrapping="NoWrap"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     CornerRadius="0"
                                     Padding="6,4"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Center"/>

                            <!-- Warning icon: visible when path is invalid and non-empty -->
                            <Border x:Name="PART_WarningDisplay"
                                    Grid.Column="1"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False"
                                    Padding="4,2"
                                    ToolTipService.ToolTip="{TemplateBinding InvalidPathReason}">
                                <FontIcon Glyph="&#xE7BA;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="14"
                                          Foreground="{ThemeResource AJut_PathSelectionControl_WarningIconForeground}"/>
                            </Border>

                            <!-- Show in Explorer button (hidden until IsOpenInExplorerButtonAllowed and IsPathValid) -->
                            <Button x:Name="PART_ShowInExplorerButton"
                                    Grid.Column="2"
                                    Visibility="Collapsed"
                                    Padding="10,6"
                                    BorderThickness="1,0,0,0"
                                    BorderBrush="{ThemeResource AJut_PathSelectionControl_ButtonBorderBrush}"
                                    Background="Transparent"
                                    ToolTipService.ToolTip="Show in Explorer">
                                <FontIcon Glyph="{TemplateBinding OpenInExplorerMDL2Icon}"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="14"
                                          Foreground="{ThemeResource AJut_PathSelectionControl_ButtonIconForeground}"/>
                            </Button>

                            <!-- Browse button -->
                            <Button x:Name="PART_BrowseButton"
                                    Grid.Column="3"
                                    Padding="10,6"
                                    BorderThickness="1,0,0,0"
                                    BorderBrush="{ThemeResource AJut_PathSelectionControl_ButtonBorderBrush}"
                                    Background="Transparent"
                                    ToolTipService.ToolTip="{TemplateBinding BrowsePrompt}">
                                <FontIcon Glyph="{TemplateBinding DefaultButtonMDL2Icon}"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="14"
                                          Foreground="{ThemeResource AJut_PathSelectionControl_ButtonIconForeground}"/>
                            </Button>

                        </Grid>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="BorderStates">
                                <!-- Normal: explicit revert — WinUI3 Setters do not auto-revert on state exit -->
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="PART_Root.BorderBrush"
                                                Value="{ThemeResource AJut_PathSelectionControl_NormalBorderBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Focused">
                                    <VisualState.Setters>
                                        <Setter Target="PART_Root.BorderBrush"
                                                Value="{ThemeResource AJut_PathSelectionControl_FocusedBorderBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PathInvalid">
                                    <VisualState.Setters>
                                        <Setter Target="PART_Root.BorderBrush"
                                                Value="#C00000"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="WarningDisplayStates">
                                <!-- WarningHidden: explicit revert — WinUI3 Setters do not auto-revert on state exit -->
                                <VisualState x:Name="WarningHidden">
                                    <VisualState.Setters>
                                        <Setter Target="PART_WarningDisplay.Visibility" Value="Collapsed"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="WarningShown">
                                    <VisualState.Setters>
                                        <Setter Target="PART_WarningDisplay.Visibility"
                                                Value="Visible"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="ExplorerButtonStates">
                                <VisualState x:Name="ExplorerButtonHidden"/>
                                <VisualState x:Name="ExplorerButtonShown">
                                    <VisualState.Setters>
                                        <Setter Target="PART_ShowInExplorerButton.Visibility"
                                                Value="Visible"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
