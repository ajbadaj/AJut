<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <!-- ===[ PathSelectionControl ]=== -->
    <!-- Default style: WinUI3 system resources only, no AJut_ brush keys.
         AllControlThemeOverrides.xaml provides the AJut-branded variant.
         Template parts: PART_Root, PART_PathTextBox, PART_BrowseButton,
         PART_ShowInExplorerButton (optional, collapsed unless IsOpenInExplorerButtonAllowed).
         VSM groups: BorderStates (Normal/Focused/PathInvalid),
                     WarningDisplayStates (WarningHidden/WarningShown),
                     ExplorerButtonStates (ExplorerButtonHidden/ExplorerButtonShown). -->
    <Style TargetType="local:PathSelectionControl">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="{ThemeResource TextControlBackground}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource TextControlBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1,1,1,2"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="TextBoxPadding" Value="2"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="TextBoxHeight" Value="22"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PathSelectionControl">
                    <Border x:Name="PART_Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0,3,3,0"
                            ToolTipService.ToolTip="{TemplateBinding CurrentToolTip}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Path entry TextBox -->
                            <Border x:Name="RimLighting_Bright" Grid.Column="0" BorderBrush="Transparent" BorderThickness="0,0,1,1" Margin="3">
                                <Border x:Name="RimLighting_Dark" BorderBrush="Transparent" BorderThickness="1.4,1.4,0,0">
                                    <TextBox x:Name="PART_PathTextBox"
                                             Header="{TemplateBinding TextBoxHeader}"
                                             Height="{TemplateBinding TextBoxHeight}"
                                             PlaceholderText="{TemplateBinding UnsetTextPrompt}"
                                             FontFamily="{TemplateBinding FontFamily}"
                                             TextWrapping="NoWrap"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             CornerRadius="0"
                                             Padding="{TemplateBinding TextBoxPadding}"
                                             Margin="{TemplateBinding Padding}"
                                             VerticalAlignment="Stretch"
                                             VerticalContentAlignment="Center">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <ContentPresenter x:Name="HeaderContentPresenter" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}" FontWeight="Normal" Foreground="{ThemeResource TextControlHeaderForeground}" Margin="{ThemeResource TextBoxTopHeaderMargin}" TextWrapping="Wrap" VerticalAlignment="Top" Visibility="Collapsed" x:DeferLoadStrategy="Lazy" />
                                                                <ScrollViewer x:Name="ContentElement" Grid.Row="1" Grid.Column="0" HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}" HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}" VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}" VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}" IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}" IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}" IsDeferredScrollingEnabled="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}" Margin="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" Foreground="{TemplateBinding Foreground}" IsTabStop="False" AutomationProperties.AccessibilityView="Raw" ZoomMode="Disabled" />
                                                                <TextBlock x:Name="PlaceholderTextContentPresenter" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Foreground="{Binding PlaceholderForeground, RelativeSource={RelativeSource TemplatedParent}, TargetNullValue={ThemeResource TextControlPlaceholderForeground}}" Margin="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" Text="{TemplateBinding PlaceholderText}" TextAlignment="{TemplateBinding TextAlignment}" TextWrapping="{TemplateBinding TextWrapping}" IsHitTestVisible="False" />
                                                                <ContentPresenter x:Name="DescriptionPresenter"
                                                                                  Grid.Row="2"
                                                                                  Grid.Column="0"
                                                                                  Grid.ColumnSpan="2"
                                                                                  Content="{TemplateBinding Description}"
                                                                                  Foreground="{ThemeResource SystemControlDescriptionTextForegroundBrush}"
                                                                                  AutomationProperties.AccessibilityView="Raw"
                                                                                  x:Load="False"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Border>
                            </Border>

                            <!-- Warning icon: visible when path is invalid and non-empty -->
                            <Border x:Name="PART_WarningDisplay"
                                    Grid.Column="1"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False"
                                    Padding="4,2"
                                    ToolTipService.ToolTip="{TemplateBinding InvalidPathReason}">
                                <FontIcon Glyph="&#xE7BA;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="14"
                                          Foreground="{ThemeResource AJut_PathSelectionControl_WarningIconForeground}"/>
                            </Border>

                            <!-- Show in Explorer button (hidden until IsOpenInExplorerButtonAllowed and IsPathValid) -->
                            <Button x:Name="PART_ShowInExplorerButton"
                                    Grid.Column="2"
                                    Visibility="Collapsed"
                                    Padding="10,6"
                                    BorderThickness="0"
                                    BorderBrush="{ThemeResource AJut_PathSelectionControl_ButtonBorderBrush}"
                                    Background="Transparent"
                                    ToolTipService.ToolTip="Show in Explorer">
                                <FontIcon Glyph="{TemplateBinding OpenInExplorerMDL2Icon}"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="14"
                                          Foreground="{ThemeResource AJut_PathSelectionControl_ButtonIconForeground}"/>
                            </Button>

                            <!-- Browse button -->
                            <Button x:Name="PART_BrowseButton"
                                    Grid.Column="3"
                                    Padding="10,6"
                                    BorderThickness="0,0,0,0"
                                    Margin="0,0,3,0"
                                    BorderBrush="{ThemeResource AJut_PathSelectionControl_ButtonBorderBrush}"
                                    Background="Transparent"
                                    ToolTipService.ToolTip="{TemplateBinding BrowsePrompt}">
                                <FontIcon Glyph="{TemplateBinding DefaultButtonMDL2Icon}"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="14"
                                          Foreground="{ThemeResource AJut_PathSelectionControl_ButtonIconForeground}"/>
                            </Button>

                        </Grid>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="BorderStates">
                                <!-- Normal: explicit revert — WinUI3 Setters do not auto-revert on state exit -->
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="PART_Root.BorderBrush"
                                                Value="{ThemeResource AJut_PathSelectionControl_NormalBorderBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Focused">
                                    <VisualState.Setters>
                                        <Setter Target="PART_Root.BorderBrush" Value="{ThemeResource AJut_PathSelectionControl_FocusedBorderBrush}"/>
                                        <Setter Target="RimLighting_Bright.BorderBrush" Value="#5FFF"/>
                                        <Setter Target="RimLighting_Dark.BorderBrush" Value="#8000"/>
                                        <Setter Target="RimLighting_Dark.Background" Value="{ThemeResource AJut_PathSelectionControl_FocusedTextBoxBackgroundBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PathInvalid">
                                    <VisualState.Setters>
                                        <Setter Target="PART_Root.BorderBrush"
                                                Value="#C00000"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="WarningDisplayStates">
                                <!-- WarningHidden: explicit revert — WinUI3 Setters do not auto-revert on state exit -->
                                <VisualState x:Name="WarningHidden">
                                    <VisualState.Setters>
                                        <Setter Target="PART_WarningDisplay.Visibility" Value="Collapsed"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="WarningShown">
                                    <VisualState.Setters>
                                        <Setter Target="PART_WarningDisplay.Visibility" Value="Visible"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="ExplorerButtonStates">
                                <VisualState x:Name="ExplorerButtonHidden"/>
                                <VisualState x:Name="ExplorerButtonShown">
                                    <VisualState.Setters>
                                        <Setter Target="PART_ShowInExplorerButton.Visibility"
                                                Value="Visible"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
