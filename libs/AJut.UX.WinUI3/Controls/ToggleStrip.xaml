<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <!-- ===[ ToggleStrip ]=== -->
    <!-- Default style: WinUI3 system resources only, no AJut_ brush keys.
         AllControlThemeOverrides.xaml provides the AJut-branded variant.
         PART_ItemsPanel is a StackPanel; code populates it with ToggleButtons. -->
    <Style TargetType="local:ToggleStrip">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:ToggleStrip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Border.Resources>
                            <!-- "Depressed button" gradient for checked ToggleButtons within the strip.
                                 Dark at top fades lighter toward bottom — simulates a sunken surface.
                                 These override the WinUI3 default ToggleButton theme resources locally
                                 so only buttons inside this ToggleStrip get the effect. -->
                            <LinearGradientBrush x:Key="ToggleButtonBackgroundChecked"
                                                 StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.00" Color="#CC000000"/>
                                <GradientStop Offset="0.20" Color="#80000000"/>
                                <GradientStop Offset="1.00" Color="#33000000"/>
                            </LinearGradientBrush>
                            <LinearGradientBrush x:Key="ToggleButtonBackgroundCheckedPointerOver"
                                                 StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.00" Color="#CC000000"/>
                                <GradientStop Offset="0.20" Color="#99000000"/>
                                <GradientStop Offset="1.00" Color="#55000000"/>
                            </LinearGradientBrush>
                            <LinearGradientBrush x:Key="ToggleButtonBackgroundCheckedPressed"
                                                 StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.00" Color="#EE000000"/>
                                <GradientStop Offset="0.20" Color="#AA000000"/>
                                <GradientStop Offset="1.00" Color="#66000000"/>
                            </LinearGradientBrush>
                        </Border.Resources>
                        <StackPanel x:Name="PART_ItemsPanel"
                                    Orientation="Horizontal"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
