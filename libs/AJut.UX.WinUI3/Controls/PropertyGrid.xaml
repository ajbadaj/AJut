<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls"
                    xmlns:prop="using:AJut.UX.PropertyInteraction">

    <!-- ===[ PropertyGrid: no-chrome ListViewItem style ]=== -->
    <!-- Minimal ListViewItem for PropertyGrid rows: suppresses full-row selection
         highlight so PropertyGridItemRow's own SelectionStates VSM (label-only highlight)
         is the only visual selection indicator. -->
    <Style x:Key="PropertyGrid_ListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="UseSystemFocusVisuals" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===[ Default label DataTemplates ]=== -->
    <!-- DataContext for both is PropertyEditTarget (passed via PropertyGridItemRow.PART_LabelContent.Content). -->

    <!-- DefaultValueLabelDataTemplate: plain label - value is at its default. -->
    <DataTemplate x:Key="PropertyGrid_DefaultLabelTemplate">
        <TextBlock Text="{Binding DisplayName}"
                   VerticalAlignment="Center"
                   Margin="6,3,8,3"
                   Opacity="0.8"
                   TextTrimming="CharacterEllipsis"
                   ToolTipService.ToolTip="{Binding DisplayName}"
                   Foreground="{ThemeResource AJut_PropertyGridItemRow_LabelForeground}"/>
    </DataTemplate>

    <!-- ModifiedValueLabelDataTemplate: bold label - value has been changed from its default. -->
    <DataTemplate x:Key="PropertyGrid_ModifiedLabelTemplate">
        <TextBlock Text="{Binding DisplayName}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Margin="6,3,8,3"
                   Opacity="0.8"
                   TextTrimming="CharacterEllipsis"
                   ToolTipService.ToolTip="{Binding DisplayName}"
                   Foreground="{ThemeResource AJut_PropertyGridItemRow_LabelForeground}"/>
    </DataTemplate>

    <!-- ===[ PropertyGrid style ]=== -->
    <!-- Uses FlatTreeListControl so that complex reference-type properties can be
         expanded to show their sub-properties as indented child rows.
         RootItemsSource is pushed in code (OnApplyTemplate / RebuildEditTargets) rather
         than via TemplateBinding because WinUI3 TemplateBinding does not read the source
         DP's current value at binding-establishment time.
         RowTemplate DataContext is FlatTreeItem (from FlatTreeListControl). PropertyGridItemRow
         accesses FlatTreeItem properties directly (IndentWidth for label width, IsSelected
         for selection VSM) and uses Source.* for property display. -->
    <Style TargetType="local:PropertyGrid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <!-- Default label templates: plain vs bold TextBlock keyed on IsAtDefaultValue. -->
        <Setter Property="DefaultValueLabelDataTemplate" Value="{StaticResource PropertyGrid_DefaultLabelTemplate}"/>
        <Setter Property="ModifiedValueLabelDataTemplate" Value="{StaticResource PropertyGrid_ModifiedLabelTemplate}"/>
        <!-- Default container style: suppresses full-row chrome so PropertyGridItemRow's
             own label-only SelectionStates VSM is the only selection indicator. -->
        <Setter Property="ListViewItemContainerStyle" Value="{StaticResource PropertyGrid_ListViewItemStyle}"/>
        <Setter Property="RowTemplate">
            <Setter.Value>
                <DataTemplate>
                    <!-- DataContext = FlatTreeItem. PropertyGridItemRow accesses both
                         FlatTreeItem (for IndentWidth/IsSelected) and Source (PropertyEditTarget). -->
                    <local:PropertyGridItemRow HorizontalAlignment="Stretch"/>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="0,0,8,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PropertyGrid">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <local:FlatTreeListControl x:Name="PART_TreeList"
                                                   ItemTemplate="{TemplateBinding RowTemplate}"
                                                   ListViewItemContainerStyle="{TemplateBinding ListViewItemContainerStyle}"
                                                   TreeDepthIndentSize="{TemplateBinding TreeDepthIndentSize}"
                                                   RowSpacing="{TemplateBinding RowSpacing}"
                                                   FixedRowHeight="{TemplateBinding FixedRowHeight}"
                                                   Background="Transparent"
                                                   BorderThickness="0"
                                                   Padding="{TemplateBinding Padding}"
                                                   HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
