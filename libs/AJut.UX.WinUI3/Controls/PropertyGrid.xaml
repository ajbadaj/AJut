<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <!-- ===[ PropertyGrid style ]=== -->
    <!-- Uses FlatTreeListControl so that complex reference-type properties can be
         expanded to show their sub-properties as indented child rows.
         RootItemsSource is pushed in code (OnApplyTemplate / RebuildEditTargets) rather
         than via TemplateBinding because WinUI3 TemplateBinding does not read the source
         DP's current value at binding-establishment time — so if RebuildEditTargets ran
         before the tab/page containing the PropertyGrid was first shown, the binding would
         always see null. PropertyGrid.cs handles both orderings explicitly.
         RowTemplate DataTemplate: DataContext is FlatTreeItem, but we set
         PropertyGridItemRow.DataContext = {Binding Source} so its bindings
         ({Binding DisplayName}, etc.) see PropertyEditTarget directly.
         EditorTemplateSelector is resolved by PropertyGridItemRow.Loaded walking
         up the visual tree to find the enclosing PropertyGrid. -->
    <Style TargetType="local:PropertyGrid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="RowTemplate">
            <Setter.Value>
                <DataTemplate>
                    <!-- DataContext = FlatTreeItem (from FlatTreeListControl).
                         Set DataContext on PropertyGridItemRow to FlatTreeItem.Source
                         so its template sees PropertyEditTarget. -->
                    <local:PropertyGridItemRow DataContext="{Binding Source}"
                                               HorizontalAlignment="Stretch"/>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PropertyGrid">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <local:FlatTreeListControl x:Name="PART_TreeList"
                                                   ItemTemplate="{TemplateBinding RowTemplate}"
                                                   Background="Transparent"
                                                   BorderThickness="0"
                                                   HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
