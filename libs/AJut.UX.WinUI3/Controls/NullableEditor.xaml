<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <!-- ===[ NullableEditor ]=== -->
    <!-- Editor for Nullable<T> properties. Shows the inner T editor (dimmed at 0.4 opacity)
         with a "Not set" overlay when the value is null. Set/Unset buttons toggle the state.
         ProxyTarget is a PropertyEditTarget for the unwrapped T value, so the inner editor
         (selected via InnerEditorTemplateSelector) always receives a non-null T value. -->

    <Style TargetType="local:NullableEditor">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:NullableEditor">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <!-- Editor column: fills remaining space -->
                            <ColumnDefinition Width="*"/>
                            <!-- [Unset] button column: auto-sized, only visible when HasValue -->
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Inner editor: always present. Opacity driven by NullableStates VSM.
                             ProxyTarget gives the inner editor a non-null T (defaulting to default(T)
                             when the outer is null), so the editor always has something to display. -->
                        <ContentControl x:Name="PART_InnerContent"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding ProxyTarget}"
                                        ContentTemplateSelector="{TemplateBinding InnerEditorTemplateSelector}"/>

                        <!-- Null overlay: sits on top of the inner editor column.
                             IsHitTestVisible=True blocks clicks through to the editor when null.
                             Background drive by NullableStates VSM. -->
                        <Grid x:Name="PART_NullOverlay"
                              Grid.Column="0"
                              IsHitTestVisible="True">
                            <Border x:Name="PART_OverlayDarken"
                                    Background="{ThemeResource AJut_NullableEditor_OverlayBackground}"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="4,0">
                                <TextBlock Text="Not set"
                                           VerticalAlignment="Center"
                                           Margin="4,0,6,0"
                                           Opacity="0.9"
                                           Foreground="{ThemeResource AJut_NullableEditor_NotSetForeground}"/>
                                <Button x:Name="PART_SetButton"
                                        Content="Set"
                                        Padding="8,3"
                                        Margin="2,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- [Unset] button: shown when EditValue is non-null. -->
                        <Button x:Name="PART_UnsetButton"
                                Grid.Column="1"
                                Content="Unset"
                                Padding="8,3"
                                Margin="3,0,0,0"
                                Visibility="Collapsed"/>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="NullableStates">
                                <!-- IsNull: overlay visible, editor dimmed to 0.4, unset button hidden -->
                                <VisualState x:Name="IsNull">
                                    <VisualState.Setters>
                                        <Setter Target="PART_NullOverlay.Visibility" Value="Visible"/>
                                        <Setter Target="PART_InnerContent.Opacity" Value="0.4"/>
                                        <Setter Target="PART_UnsetButton.Visibility" Value="Collapsed"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <!-- HasValue: overlay hidden, editor full opacity, unset button visible -->
                                <VisualState x:Name="HasValue">
                                    <VisualState.Setters>
                                        <Setter Target="PART_NullOverlay.Visibility" Value="Collapsed"/>
                                        <Setter Target="PART_InnerContent.Opacity" Value="1.0"/>
                                        <Setter Target="PART_UnsetButton.Visibility" Value="Visible"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
