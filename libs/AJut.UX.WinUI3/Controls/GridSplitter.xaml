<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">

    <Style TargetType="local:GridSplitter">
        <Setter Property="IsTabStop" Value="False"/>
        <!-- Default stripe color: subtle gray, readable without any AJut theme loaded.
             AllControlThemeOverrides.xaml overrides this to AJut_Brush_BorderCommon. -->
        <Setter Property="Background" Value="#40808080"/>
        <Setter Property="Thickness" Value="2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:GridSplitter">
                    <!-- Grid background is always transparent for pointer hit-testing. -->
                    <Grid Background="Transparent">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="OrientationStates">
                                <!-- Resizes adjacent columns: vertical 1px stripe centered in the bar -->
                                <VisualState x:Name="ColumnResize">
                                    <VisualState.Setters>
                                        <Setter Target="PART_ColumnStripe.Opacity" Value="1"/>
                                        <Setter Target="PART_RowStripe.Opacity" Value="0"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <!-- Resizes adjacent rows: horizontal 1px stripe centered in the bar -->
                                <VisualState x:Name="RowResize">
                                    <VisualState.Setters>
                                        <Setter Target="PART_ColumnStripe.Opacity" Value="0"/>
                                        <Setter Target="PART_RowStripe.Opacity" Value="1"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <!-- Vertical stripe: shown when resizing adjacent columns -->
                        <Rectangle x:Name="PART_ColumnStripe"
                                   Fill="{TemplateBinding Background}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   MinWidth="{TemplateBinding Thickness}"
                                   MinHeight="{TemplateBinding Thickness}"
                                   Opacity="0"/>

                        <!-- Horizontal stripe: shown when resizing adjacent rows -->
                        <Rectangle x:Name="PART_RowStripe"
                                   Fill="{TemplateBinding Background}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   MinWidth="{TemplateBinding Thickness}"
                                   MinHeight="{TemplateBinding Thickness}"
                                   Opacity="0"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
