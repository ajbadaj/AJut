<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="using:System">

    <!-- ===[ Corner Radius ]=== -->
    <!-- Matches WPF AJut aesthetic: minimal rounding -->
    <CornerRadius x:Key="ControlCornerRadius">2</CornerRadius>

    <!-- ===[ Accent Colors ]=== -->
    <StaticResource x:Key="SystemAccentColor" ResourceKey="AJut_Color_PrimaryHighlight" />
    <StaticResource x:Key="SystemAccentColorDark1" ResourceKey="AJut_Color_PrimaryHighlightDark" />
    <StaticResource x:Key="SystemAccentColorLight1" ResourceKey="AJut_Color_PrimaryHighlightBright" />
    <StaticResource x:Key="SystemAccentColorLight2" ResourceKey="AJut_Color_PrimaryHighlightDesat" />
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{ThemeResource AJut_Color_PrimaryHighlight}" />

    <StaticResource x:Key="SystemAccentColor2" ResourceKey="AJut_Color_SecondaryHighlight" />
    <StaticResource x:Key="SystemAccentColor2Dark1" ResourceKey="AJut_Color_SecondaryHighlightDark" />
    <StaticResource x:Key="SystemAccentColor2Light1" ResourceKey="AJut_Color_SecondaryHighlightBright" />
    <StaticResource x:Key="SystemAccentColor2Light2" ResourceKey="AJut_Color_SecondaryHighlightDesat" />

    <!-- ===[ Text Brushes ]=== -->
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{ThemeResource AJut_Color_NormalText}"/>
    <SolidColorBrush x:Key="TextBoxForegroundThemeBrush" Color="{ThemeResource AJut_Color_NormalText}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{ThemeResource AJut_Color_InteractiveText}"/>
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{ThemeResource AJut_Color_HighlightText}"/>
    <SolidColorBrush x:Key="DefaultTextForegroundThemeBrush" Color="{ThemeResource AJut_Color_NormalText}"/>
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{ThemeResource AJut_Color_NormalText}"/>

    <!-- ===[ List Accent Brushes ]=== -->
    <StaticResource x:Key="SystemListAccentLowColor" ResourceKey="AJut_Color_PrimaryHighlightDesat" />
    <StaticResource x:Key="SystemListAccentMediumColor" ResourceKey="AJut_Color_PrimaryHighlight" />
    <StaticResource x:Key="SystemListAccentHighColor" ResourceKey="AJut_Color_PrimaryHighlightBright" />
    <StaticResource x:Key="SystemListLowBrush" ResourceKey="AJut_Brush_ListBackground" />
    <StaticResource x:Key="SystemListMediumBrush" ResourceKey="AJut_Brush_ListBorder" />
    <StaticResource x:Key="SystemListAccentMediumBrush" ResourceKey="AJut_Brush_ListSelection" />

    <!-- ===[ TitleBar / Chrome Colors ]=== -->
    <StaticResource x:Key="SystemChromeBlackHighBrush" ResourceKey="AJut_Brush_ChromeButtonHoverBackground" />
    <StaticResource x:Key="TitleBarCaptionButtonHoverForegroundColor" ResourceKey="AJut_Brush_ChromeButtonHoverBackground"/>
    <StaticResource x:Key="TitleBarCaptionButtonPressedForegroundColor" ResourceKey="AJut_Color_ChromeButtonPressedForeground"/>
    <StaticResource x:Key="TitleBarCaptionButtonInactiveForegroundColor" ResourceKey="AJut_Color_ChromeButtonInactiveForeground"/>
    <StaticResource x:Key="TitleBarCaptionButtonForegroundColor" ResourceKey="AJut_Brush_TitleBarForeground"/>
    <StaticResource x:Key="TitleBarForegroundBrush" ResourceKey="AJut_Brush_TitleBarForeground"/>
    <StaticResource x:Key="TitleBarDeactivatedForegroundBrush" ResourceKey="AJut_Brush_TitleBarForegroundDesat"/>

    <!-- ===[ TabView Colors ]=== -->
    <SolidColorBrush x:Key="TabViewBackground" Color="Transparent" />
    <SolidColorBrush x:Key="TabViewItemHeaderBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPointerOver" Color="{ThemeResource AJut_Color_InnerPanelBackgroundHover}"/>
    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="{ThemeResource AJut_Color_InnerPanelBackground}" />
    <StaticResource x:Key="TabViewItemHeaderDragBackground" ResourceKey="AJut_Brush_PopupBackground" />
    <StaticResource x:Key="TabViewItemHeaderBackgroundPressed" ResourceKey="AJut_Brush_PopupBackground" />
    <StaticResource x:Key="TabViewItemHeaderBackgroundDisabled" ResourceKey="LayerOnMicaBaseAltFillColorTransparentBrush" />

    <!-- ===[ Window Caption Colors ]=== -->
    <SolidColorBrush x:Key="WindowCaptionBackground" Color="{ThemeResource AJut_Color_ChromeButtonBackground}" />
    <SolidColorBrush x:Key="WindowCaptionBackgroundDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="WindowCaptionForeground" Color="{ThemeResource AJut_Color_ChromeButtonForeground}" />
    <StaticResource x:Key="WindowCaptionForegroundDisabled" ResourceKey="SystemControlDisabledBaseMediumLowBrush" />
    <SolidColorBrush x:Key="WindowCaptionButtonBackgroundPointerOver" Color="{ThemeResource AJut_Color_ChromeButtonHoverBackground}" />
    <StaticResource x:Key="WindowCaptionButtonBackgroundPressed" ResourceKey="SystemControlBackgroundBaseMediumLowBrush" />
    <StaticResource x:Key="WindowCaptionButtonStroke" ResourceKey="SystemControlForegroundBaseHighBrush" />
    <StaticResource x:Key="WindowCaptionButtonStrokePointerOver" ResourceKey="SystemControlForegroundBaseHighBrush" />
    <StaticResource x:Key="WindowCaptionButtonStrokePressed" ResourceKey="SystemControlForegroundBaseHighBrush" />
    <SolidColorBrush x:Key="WindowCaptionButtonBackground" Color="Transparent" />
    <SolidColorBrush x:Key="CloseButtonBackgroundPointerOver" Color="{ThemeResource AJut_Color_ChromeCloseButtonHighlight}" />
    <SolidColorBrush x:Key="CloseButtonStrokePointerOver" Color="{ThemeResource AJut_Color_ChromeButtonHoverForeground}" />
    <SolidColorBrush x:Key="CloseButtonBackgroundPressed" Color="{ThemeResource AJut_Color_ChromeCloseButtonComplement}" />
    <SolidColorBrush x:Key="CloseButtonStrokePressed" Color="{ThemeResource AJut_Color_ChromeCloseButtonHoverForeground}" />

    <!-- ===[ ControlFill (backing TextBox, ComboBox, etc.) ]=== -->
    <StaticResource x:Key="ControlFillColorDefaultBrush" ResourceKey="AJut_Brush_ControlBackground"/>
    <StaticResource x:Key="ControlFillColorSecondaryBrush" ResourceKey="AJut_Brush_ControlBackgroundHover"/>
    <StaticResource x:Key="ControlFillColorInputActiveBrush" ResourceKey="AJut_Brush_ControlBackground"/>

    <!-- ===[ TextControl (TextBox, PasswordBox, etc.) ]=== -->
    <StaticResource x:Key="TextControlForeground" ResourceKey="AJut_Color_NormalText" />
    <StaticResource x:Key="TextControlForegroundPointerOver" ResourceKey="AJut_Color_HighlightText" />
    <StaticResource x:Key="TextControlForegroundFocused" ResourceKey="AJut_Color_InteractiveText" />
    <StaticResource x:Key="TextControlForegroundDisabled" ResourceKey="AJut_Color_UnderstatedText" />
    <StaticResource x:Key="TextControlBackground" ResourceKey="AJut_Brush_TextBoxBackground"/>
    <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="AJut_Brush_TextBoxBackground"/>
    <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="AJut_Brush_TextBoxBackground"/>
    <StaticResource x:Key="TextControlBorderBrush" ResourceKey="AJut_Brush_TextBoxBorder"/>
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{ThemeResource AJut_Color_PrimaryHighlightBright}"/>
    <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="AJut_Brush_PrimaryHighlight"/>
    <StaticResource x:Key="TextControlPlaceholderForeground" ResourceKey="AJut_Brush_UnderstatedText"/>
    <StaticResource x:Key="TextControlPlaceholderForegroundPointerOver" ResourceKey="AJut_Brush_InteractiveTextUnfocused"/>
    <StaticResource x:Key="TextControlPlaceholderForegroundFocused" ResourceKey="AJut_Brush_UnderstatedText"/>

    <!-- ===[ Button ]=== -->
    <StaticResource x:Key="ButtonForeground" ResourceKey="AJut_Brush_NormalText"/>
    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource AJut_Color_HighlightText}"/>
    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{ThemeResource AJut_Color_ImportantText}"/>
    <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="{ThemeResource AJut_Color_UnderstatedText}"/>
    <StaticResource x:Key="ButtonBackground" ResourceKey="AJut_Brush_ControlBackground"/>
    <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="AJut_Brush_ControlBackgroundHover"/>
    <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="AJut_Brush_ButtonBackgroundPressed"/>
    <StaticResource x:Key="ButtonBorderBrush" ResourceKey="AJut_Brush_BorderCommon"/>
    <StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="AJut_Brush_BorderCommonHover"/>
    <StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="AJut_Brush_BorderCommon"/>
    <StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="AJut_Brush_BorderCommon"/>

    <!-- ===[ ToggleButton ]=== -->
    <StaticResource x:Key="ToggleButtonBackground" ResourceKey="AJut_Brush_ControlBackground"/>
    <StaticResource x:Key="ToggleButtonBackgroundPointerOver" ResourceKey="AJut_Brush_ControlBackgroundHover"/>
    <StaticResource x:Key="ToggleButtonBackgroundPressed" ResourceKey="AJut_Brush_ButtonBackgroundPressed"/>
    <StaticResource x:Key="ToggleButtonBackgroundChecked" ResourceKey="AJut_Brush_PrimaryHighlight"/>
    <StaticResource x:Key="ToggleButtonBackgroundCheckedPointerOver" ResourceKey="AJut_Brush_PrimaryHighlightBright"/>
    <StaticResource x:Key="ToggleButtonBackgroundCheckedPressed" ResourceKey="AJut_Brush_PrimaryHighlightDark"/>
    <StaticResource x:Key="ToggleButtonForeground" ResourceKey="AJut_Brush_NormalText"/>
    <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="{ThemeResource AJut_Color_HighlightText}"/>
    <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="{ThemeResource AJut_Color_HighContrastText}"/>
    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="{ThemeResource AJut_Color_ImportantText}"/>
    <SolidColorBrush x:Key="ToggleButtonForegroundDisabled" Color="{ThemeResource AJut_Color_UnderstatedText}"/>
    <StaticResource x:Key="ToggleButtonBorderBrush" ResourceKey="AJut_Brush_BorderCommon"/>
    <StaticResource x:Key="ToggleButtonBorderBrushPointerOver" ResourceKey="AJut_Brush_BorderCommonHover"/>
    <StaticResource x:Key="ToggleButtonBorderBrushChecked" ResourceKey="AJut_Brush_BorderCommonPress"/>
    <StaticResource x:Key="ToggleButtonBorderBrushCheckedPointerOver" ResourceKey="AJut_Brush_BorderCommonPress"/>
    <StaticResource x:Key="ToggleButtonBorderBrushPressed" ResourceKey="AJut_Brush_BorderCommon"/>

    <!-- ===[ ComboBox ]=== -->
    <StaticResource x:Key="ComboBoxBackground" ResourceKey="AJut_Brush_PopOutControlBackground"/>
    <StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="AJut_Brush_ControlBackgroundHover"/>
    <StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="AJut_Brush_ButtonBackgroundPressed"/>
    <StaticResource x:Key="ComboBoxForeground" ResourceKey="AJut_Brush_InteractiveTextUnfocused"/>
    <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="{ThemeResource AJut_Color_HighlightText}"/>
    <SolidColorBrush x:Key="ComboBoxForegroundFocused" Color="{ThemeResource AJut_Color_InteractiveText}"/>
    <SolidColorBrush x:Key="ComboBoxForegroundDisabled" Color="{ThemeResource AJut_Color_UnderstatedText}"/>
    <StaticResource x:Key="ComboBoxBorderBrush" ResourceKey="AJut_Brush_TextBoxBorder"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="{ThemeResource AJut_Color_PrimaryHighlightBright}"/>
    <StaticResource x:Key="ComboBoxBorderBrushFocused" ResourceKey="AJut_Brush_PrimaryHighlight"/>
    <StaticResource x:Key="ComboBoxDropDownBackground" ResourceKey="AJut_Brush_InnerPanelBackground"/>
    <StaticResource x:Key="ComboBoxDropDownBorderBrush" ResourceKey="AJut_Brush_ListSelection"/>
    <StaticResource x:Key="ComboBoxItemForeground" ResourceKey="AJut_Brush_NormalText"/>
    <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="{ThemeResource AJut_Color_HighlightText}"/>
    <StaticResource x:Key="ComboBoxItemBackgroundPointerOver" ResourceKey="AJut_Brush_ListSelectionBackground"/>
    <StaticResource x:Key="ComboBoxItemBackgroundSelected" ResourceKey="AJut_Brush_ListSelection"/>
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="{ThemeResource AJut_Color_ImportantText}"/>

    <!-- ===[ NumberBox (backing NumericEditor) ]=== -->
    <!-- NumberBoxBackground intentionally NOT overridden here — NumericEditor handles it via TemplateBinding -->
    <StaticResource x:Key="NumberBoxForeground" ResourceKey="AJut_Brush_NormalText"/>
    <StaticResource x:Key="NumberBoxBorderBrush" ResourceKey="AJut_Brush_TextBoxBorder"/>
    <StaticResource x:Key="NumberBoxBorderBrushFocused" ResourceKey="AJut_Brush_PrimaryHighlight"/>
    <SolidColorBrush x:Key="NumberBoxButtonBackground" Color="Transparent"/>
    <StaticResource x:Key="NumberBoxButtonBackgroundPointerOver" ResourceKey="AJut_Brush_MouseInteractionHighlight"/>
    <StaticResource x:Key="NumberBoxButtonBackgroundPressed" ResourceKey="AJut_Brush_PrimaryHighlightDark"/>
    <StaticResource x:Key="NumberBoxButtonForeground" ResourceKey="AJut_Brush_SymbolForeground"/>
    <StaticResource x:Key="NumberBoxButtonForegroundPointerOver" ResourceKey="AJut_Brush_SymbolForegroundHighlight"/>
    <StaticResource x:Key="NumberBoxButtonForegroundPressed" ResourceKey="AJut_Brush_SymbolForegroundHighlight"/>

    <!-- ===[ ToggleSwitch ]=== -->
    <StaticResource x:Key="ToggleSwitchFillOn" ResourceKey="AJut_Brush_PrimaryHighlight"/>
    <StaticResource x:Key="ToggleSwitchFillOnPointerOver" ResourceKey="AJut_Brush_PrimaryHighlightBright"/>
    <StaticResource x:Key="ToggleSwitchFillOnPressed" ResourceKey="AJut_Brush_PrimaryHighlightDark"/>
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPressed" Color="#EEEEEE"/>
    <StaticResource x:Key="ToggleSwitchFillOff" ResourceKey="AJut_Brush_InnerPanelBackground"/>
    <StaticResource x:Key="ToggleSwitchFillOffPointerOver" ResourceKey="AJut_Brush_ControlBackgroundHover"/>
    <StaticResource x:Key="ToggleSwitchFillOffPressed" ResourceKey="AJut_Brush_ButtonBackgroundPressed"/>
    <StaticResource x:Key="ToggleSwitchStrokeOff" ResourceKey="AJut_Brush_BorderCommon"/>
    <StaticResource x:Key="ToggleSwitchStrokeOffPointerOver" ResourceKey="AJut_Brush_BorderCommonHover"/>
    <StaticResource x:Key="ToggleSwitchStrokeOn" ResourceKey="AJut_Brush_PrimaryHighlightDark"/>
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="{ThemeResource AJut_Color_SymbolForeground}"/>
    <SolidColorBrush x:Key="ToggleSwitchHeaderForeground" Color="{ThemeResource AJut_Color_NormalText}"/>

    <!-- ===[ Expander ]=== -->
    <StaticResource x:Key="ExpanderBackground" ResourceKey="AJut_Brush_InnerPanelBackground"/>
    <StaticResource x:Key="ExpanderBorderBrush" ResourceKey="AJut_Brush_BorderCommon"/>
    <StaticResource x:Key="ExpanderHeaderBackground" ResourceKey="AJut_Brush_BannerBackground"/>
    <StaticResource x:Key="ExpanderHeaderBackgroundPointerOver" ResourceKey="AJut_Brush_ControlBackgroundHover"/>
    <StaticResource x:Key="ExpanderHeaderBackgroundPressed" ResourceKey="AJut_Brush_ButtonBackgroundPressed"/>
    <StaticResource x:Key="ExpanderHeaderForeground" ResourceKey="AJut_Brush_NormalText"/>
    <SolidColorBrush x:Key="ExpanderHeaderForegroundPointerOver" Color="{ThemeResource AJut_Color_HighlightText}"/>
    <StaticResource x:Key="ExpanderHeaderBorderBrush" ResourceKey="AJut_Brush_BorderCommon"/>
    <StaticResource x:Key="ExpanderHeaderBorderBrushPointerOver" ResourceKey="AJut_Brush_BorderCommonHover"/>
    <StaticResource x:Key="ExpanderContentBackground" ResourceKey="AJut_Brush_PanelBackground"/>
    <StaticResource x:Key="ExpanderContentBorderBrush" ResourceKey="AJut_Brush_BorderCommon"/>
    <SolidColorBrush x:Key="ExpanderChevronBackground" Color="Transparent"/>
    <StaticResource x:Key="ExpanderChevronBackgroundPointerOver" ResourceKey="AJut_Brush_MouseInteractionHighlight"/>
    <StaticResource x:Key="ExpanderChevronBackgroundPressed" ResourceKey="AJut_Brush_PrimaryHighlightDark"/>
    <StaticResource x:Key="ExpanderChevronForeground" ResourceKey="AJut_Brush_SymbolForeground"/>
    <StaticResource x:Key="ExpanderChevronForegroundPointerOver" ResourceKey="AJut_Brush_SymbolForegroundHighlight"/>
    <StaticResource x:Key="ExpanderChevronForegroundPressed" ResourceKey="AJut_Brush_SymbolForegroundHighlight"/>

    <!-- ===[ MenuFlyout / ContextFlyout ]=== -->
    <StaticResource x:Key="MenuFlyoutPresenterBackground" ResourceKey="AJut_Brush_InnerPanelBackground"/>
    <StaticResource x:Key="MenuFlyoutPresenterBorderBrush" ResourceKey="AJut_Brush_ListSelection"/>
    <SolidColorBrush x:Key="MenuFlyoutItemBackground" Color="Transparent"/>
    <StaticResource x:Key="MenuFlyoutItemBackgroundPointerOver" ResourceKey="AJut_Brush_ListSelectionBackground"/>
    <StaticResource x:Key="MenuFlyoutItemBackgroundPressed" ResourceKey="AJut_Brush_PrimaryHighlightDark"/>
    <StaticResource x:Key="MenuFlyoutItemForeground" ResourceKey="AJut_Brush_NormalText"/>
    <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver" Color="{ThemeResource AJut_Color_HighlightText}"/>
    <StaticResource x:Key="MenuFlyoutSeparatorBrush" ResourceKey="AJut_Brush_BorderCommon"/>
    <StaticResource x:Key="MenuFlyoutSubItemChevron" ResourceKey="AJut_Brush_SymbolForeground"/>

    <!-- ===[ MenuBar ]=== -->
    <StaticResource x:Key="MenuBarBackground" ResourceKey="AJut_Brush_BannerBackground"/>
    <StaticResource x:Key="MenuBarBorderBrush" ResourceKey="AJut_Brush_BorderCommon"/>
    <SolidColorBrush x:Key="MenuBarItemBackground" Color="Transparent"/>
    <StaticResource x:Key="MenuBarItemBackgroundPointerOver" ResourceKey="AJut_Brush_MouseInteractionHighlight"/>
    <StaticResource x:Key="MenuBarItemBackgroundSelected" ResourceKey="AJut_Brush_PrimaryHighlight"/>
    <StaticResource x:Key="MenuBarItemBackgroundPressed" ResourceKey="AJut_Brush_PrimaryHighlightDark"/>
    <StaticResource x:Key="MenuBarItemForeground" ResourceKey="AJut_Brush_NormalText"/>
    <SolidColorBrush x:Key="MenuBarItemForegroundPointerOver" Color="{ThemeResource AJut_Color_HighlightText}"/>
    <SolidColorBrush x:Key="MenuBarItemForegroundSelected" Color="{ThemeResource AJut_Color_ImportantText}"/>

    <!-- ===[ DropDownButton ]=== -->
    <StaticResource x:Key="DropDownButtonBackground" ResourceKey="AJut_Brush_ControlBackground"/>
    <StaticResource x:Key="DropDownButtonBackgroundPointerOver" ResourceKey="AJut_Brush_ControlBackgroundHover"/>
    <StaticResource x:Key="DropDownButtonBackgroundPressed" ResourceKey="AJut_Brush_ButtonBackgroundPressed"/>
    <StaticResource x:Key="DropDownButtonForeground" ResourceKey="AJut_Brush_NormalText"/>
    <SolidColorBrush x:Key="DropDownButtonForegroundPointerOver" Color="{ThemeResource AJut_Color_HighlightText}"/>
    <StaticResource x:Key="DropDownButtonBorderBrush" ResourceKey="AJut_Brush_BorderCommon"/>
    <StaticResource x:Key="DropDownButtonBorderBrushPointerOver" ResourceKey="AJut_Brush_BorderCommonHover"/>

    <!-- ===[ CheckBox ]=== -->
    <StaticResource x:Key="CheckBoxForeground" ResourceKey="AJut_Brush_NormalText"/>
    <StaticResource x:Key="CheckBoxCheckBackgroundFillChecked" ResourceKey="AJut_Brush_PrimaryHighlight"/>
    <StaticResource x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" ResourceKey="AJut_Brush_PrimaryHighlightBright"/>
    <StaticResource x:Key="CheckBoxCheckBackgroundFillCheckedPressed" ResourceKey="AJut_Brush_PrimaryHighlightDark"/>
    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeUnchecked" ResourceKey="AJut_Brush_BorderCommon"/>
    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeUncheckedPointerOver" ResourceKey="AJut_Brush_BorderCommonHover"/>
    <StaticResource x:Key="CheckBoxCheckGlyphForegroundChecked" ResourceKey="AJut_Brush_ImportantText"/>

    <!-- ===[ RadioButton ]=== -->
    <StaticResource x:Key="RadioButtonForeground" ResourceKey="AJut_Brush_NormalText"/>
    <StaticResource x:Key="RadioButtonOuterEllipseStroke" ResourceKey="AJut_Brush_BorderCommon"/>
    <StaticResource x:Key="RadioButtonOuterEllipseStrokePointerOver" ResourceKey="AJut_Brush_BorderCommonHover"/>
    <StaticResource x:Key="RadioButtonOuterEllipseCheckedStroke" ResourceKey="AJut_Brush_PrimaryHighlight"/>
    <StaticResource x:Key="RadioButtonOuterEllipseCheckedFill" ResourceKey="AJut_Brush_PrimaryHighlight"/>
    <StaticResource x:Key="RadioButtonCheckGlyphFill" ResourceKey="AJut_Brush_ImportantText"/>

    <!-- ===[ ScrollViewer / ScrollBar ]=== -->
    <!-- NOTE: These keys must be Color type (not Brush) — WinUI3's ScrollBar template uses them   -->
    <!-- as Color="{ThemeResource ScrollBarThumb*}" inside its own SolidColorBrush declarations.   -->
    <!-- Overriding them as SolidColorBrush causes: SolidColorBrush.Color ← SolidColorBrush crash. -->
    <StaticResource x:Key="ScrollBarThumbBackgroundColor" ResourceKey="AJut_Color_BorderCommon"/>
    <StaticResource x:Key="ScrollBarThumbBackgroundColorPointerOver" ResourceKey="AJut_Color_BorderCommonTransparent"/>
    <StaticResource x:Key="ScrollBarPanningThumbBackgroundColor" ResourceKey="AJut_Color_BorderCommon"/>

</ResourceDictionary>
