<?xml version="1.0" encoding="utf-8"?>
<!--
    AllControlThemeOverrides.xaml
    ==============================
    Merge this dictionary (along with a DarkThemeColorsBase.xaml or LightThemeColorsBase.xaml)
    into your Application.Resources to apply AJut theme colors to the AJut.UX.WinUI3 controls.

    The default control styles (in Generic.xaml / the individual Control XAML files) use only
    WinUI3 built-in system brushes and literal values so that controls work without any AJut
    theme loaded. Merging this dictionary overrides the relevant parts with AJut brush keys.

    Merge order in App.xaml (after a theme color dictionary):
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/DarkThemeColorsBase.xaml"/>
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/AllControlThemeOverrides.xaml"/>
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls"
                    xmlns:conv="using:AJut.UX.Converters">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/Microsoft.UI.Xaml_Overrides.xaml"/>
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/AJut.UX_Overrides.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Re-declare converter so this file is self-contained (same key as FlatTreeListControl.xaml). -->
    <conv:BooleanToVisibilityConverter x:Key="FlatTree_HasChildrenToVisibility"
                                       TrueValue="Visible"
                                       FalseValue="Collapsed"/>

    <!--
    ===[ FlatTreeItemRow - AJut-themed override ]===
    Restores AJut theme brushes for the expander button states and list selection.
    -->
    <Style TargetType="local:FlatTreeItemRow">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:FlatTreeItemRow">
                    <Grid HorizontalAlignment="Stretch"
                          Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="{Binding IndentWidth}"
                                Background="Transparent"/>

                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                      Visibility="{Binding IsExpandable, Converter={StaticResource FlatTree_HasChildrenToVisibility}}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="3"/>
                                    <Setter Property="CornerRadius" Value="2"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Root"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="{TemplateBinding CornerRadius}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <FontIcon x:Name="ExpanderIcon"
                                                              FontFamily="Segoe Fluent Icons"
                                                              FontSize="9"
                                                              Glyph="&#xE76C;"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Foreground="{ThemeResource AJut_Brush_SymbolForeground}"/>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal"/>
                                                            <VisualState x:Name="PointerOver">
                                                                <VisualState.Setters>
                                                                    <Setter Target="Root.Background"
                                                                            Value="{ThemeResource AJut_Brush_MouseInteractionHighlight}"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="Pressed">
                                                                <VisualState.Setters>
                                                                    <Setter Target="Root.Background"
                                                                            Value="{ThemeResource AJut_Brush_PrimaryHighlightDark}"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="Checked">
                                                                <VisualState.Setters>
                                                                    <Setter Target="ExpanderIcon.Glyph"
                                                                            Value="&#xE70D;"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="CheckedPointerOver">
                                                                <VisualState.Setters>
                                                                    <Setter Target="Root.Background"
                                                                            Value="{ThemeResource AJut_Brush_MouseInteractionHighlight}"/>
                                                                    <Setter Target="ExpanderIcon.Glyph"
                                                                            Value="&#xE70D;"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="CheckedPressed">
                                                                <VisualState.Setters>
                                                                    <Setter Target="Root.Background"
                                                                            Value="{ThemeResource AJut_Brush_PrimaryHighlightDark}"/>
                                                                    <Setter Target="ExpanderIcon.Glyph"
                                                                            Value="&#xE70D;"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <ContentPresenter Grid.Column="2"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          Margin="2,0"
                                          Content="{Binding .}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
    ===[ FlatTreeListControl ListViewItem - AJut-themed override ]===
    Restores AJut selection and hover brushes for the inner ListView item container.
    -->
    <Style x:Key="AJut_FlatTree_ListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Grid x:Name="ContentBorder"
                          Background="Transparent">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="SelectionStates">
                                <VisualState x:Name="Unselected"/>
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Target="ContentBorder.Background"
                                                Value="{ThemeResource AJut_Brush_ListSelection}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="SelectedUnfocused">
                                    <VisualState.Setters>
                                        <Setter Target="ContentBorder.Background"
                                                Value="{ThemeResource AJut_Brush_ListSelectionBackground}"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="ContentBorder.Background"
                                                Value="{ThemeResource AJut_Brush_ListItemHover}"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
    ===[ PropertyGridItemRow - AJut-themed override ]===
    Restores AJut_Brush_NormalText for the property label.
    -->
    <Style TargetType="local:PropertyGridItemRow">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PropertyGridItemRow">
                    <Grid HorizontalAlignment="Stretch"
                          Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding DisplayName}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontStyle="Italic"
                                   Opacity="0.8"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTipService.ToolTip="{Binding DisplayName}"
                                   Foreground="{ThemeResource AJut_Brush_NormalText}"/>

                        <ContentControl Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Content="{Binding}"
                                        ContentTemplateSelector="{TemplateBinding EditorTemplateSelector}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
