<?xml version="1.0" encoding="utf-8"?>
<!--
    AllControlThemeOverrides.xaml
    ==============================
    Merge this dictionary (along with a DarkThemeColorsBase.xaml or LightThemeColorsBase.xaml)
    into your Application.Resources to apply AJut theme colors to the AJut.UX.WinUI3 controls.

    The default control styles (in Generic.xaml / the individual Control XAML files) use only
    WinUI3 built-in system brushes and literal values so that controls work without any AJut
    theme loaded. Merging this dictionary overrides the relevant parts with AJut brush keys.

    Merge order in App.xaml (after a theme color dictionary):
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/DarkThemeColorsBase.xaml"/>
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/AllControlThemeOverrides.xaml"/>
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls"
                    xmlns:conv="using:AJut.UX.Converters">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/Microsoft.UI.Xaml_Overrides.xaml"/>
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/AJut.UX_Overrides.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Re-declare shared resources so this file is self-contained when used as an implicit-style
         override. These match the keys defined in FlatTreeListControl.xaml. -->
    <conv:BooleanToVisibilityConverter x:Key="FlatTree_HasChildrenToVisibility"
                                       TrueValue="Visible"
                                       FalseValue="Collapsed"/>
    <DataTemplate x:Key="FlatTree_RowDataTemplate">
        <local:FlatTreeItemRow HorizontalAlignment="Stretch"/>
    </DataTemplate>

    <!--
    ===[ FlatTreeListControl ListViewItem - AJut-themed override ]===
    AJut signature selection style: 4px colored strip on left edge + subtle tint
    on the row body. Overrides the same-key resource in FlatTreeListControl.xaml.

    Single CommonStates group mirrors WinUI3 ListView's state machine which uses
    combined states (PointerOverSelected, PressedSelected). Normal resets all five
    animated properties so deselection never leaves a ghost highlight behind.
    -->
    <Style x:Key="AJut_FlatTree_ListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="UseSystemFocusVisuals" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Grid x:Name="ContentBorder" Background="Transparent">
                        <Rectangle x:Name="SelectionStrip"
                                   Width="4"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Stretch"
                                   Fill="Transparent"/>
                        <!-- Selection outline: 1px box border driven by single CommonStates. -->
                        <Border x:Name="SelectionHighlight"
                                BorderThickness="1"
                                BorderBrush="Transparent"
                                Background="Transparent"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
                        <!-- Hover tint: subtle background + 1px border, rendered above SelectionHighlight. -->
                        <Border x:Name="HoverTint"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="6,0,0,0"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionStrip"
                                                                       Storyboard.TargetProperty="Fill">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionStrip"
                                                                       Storyboard.TargetProperty="Fill">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListItemHover}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_BorderCommon}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionStrip"
                                                                       Storyboard.TargetProperty="Fill">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListItemHover}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_BorderCommon}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <!-- Selected (focused): 4px nub + outline. -->
                                <VisualState x:Name="Selected">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionStrip"
                                                                       Storyboard.TargetProperty="Fill">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListSelection}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListSelection}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListSelectionBackground}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <!-- PointerOverSelected: selection nub + outline + hover tint fill. -->
                                <VisualState x:Name="PointerOverSelected">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionStrip"
                                                                       Storyboard.TargetProperty="Fill">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListSelection}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListSelection}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListSelectionBackground}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListItemHover}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <!-- PressedSelected: same as PointerOverSelected. -->
                                <VisualState x:Name="PressedSelected">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionStrip"
                                                                       Storyboard.TargetProperty="Fill">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListSelection}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListSelection}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListSelectionBackground}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListItemHover}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <!-- SelectedUnfocused: desaturated nub + outline to signal focus loss. -->
                                <VisualState x:Name="SelectedUnfocused">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionStrip"
                                                                       Storyboard.TargetProperty="Fill">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_PrimaryHighlightDesat}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_PrimaryHighlightDesat}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionHighlight"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0"
                                                                    Value="{ThemeResource AJut_Brush_ListSelectionBackground}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoverTint"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
    ===[ FlatTreeItemRow - AJut-themed override ]===
    Restores AJut theme brushes for the expander button states.
    -->
    <Style TargetType="local:FlatTreeItemRow">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:FlatTreeItemRow">
                    <Grid HorizontalAlignment="Stretch"
                          Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="{Binding IndentWidth}"
                                Background="Transparent"/>

                        <!-- Foreground passes ExpanderGlyphForeground to the nested template. -->
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                      Visibility="{Binding IsExpandable, Converter={StaticResource FlatTree_HasChildrenToVisibility}}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Foreground="{TemplateBinding ExpanderGlyphForeground}">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="3"/>
                                    <Setter Property="CornerRadius" Value="2"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Root"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="{TemplateBinding CornerRadius}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <FontIcon x:Name="ExpanderIcon"
                                                              FontFamily="Segoe Fluent Icons"
                                                              FontSize="9"
                                                              Glyph="&#xE76C;"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Foreground="{TemplateBinding Foreground}"/>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal"/>
                                                            <VisualState x:Name="PointerOver">
                                                                <VisualState.Setters>
                                                                    <Setter Target="Root.Background"
                                                                            Value="{ThemeResource AJut_Brush_MouseInteractionHighlight}"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="Pressed">
                                                                <VisualState.Setters>
                                                                    <Setter Target="Root.Background"
                                                                            Value="{ThemeResource AJut_Brush_PrimaryHighlightDark}"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="Checked">
                                                                <VisualState.Setters>
                                                                    <Setter Target="ExpanderIcon.Glyph"
                                                                            Value="&#xE70D;"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="CheckedPointerOver">
                                                                <VisualState.Setters>
                                                                    <Setter Target="Root.Background"
                                                                            Value="{ThemeResource AJut_Brush_MouseInteractionHighlight}"/>
                                                                    <Setter Target="ExpanderIcon.Glyph"
                                                                            Value="&#xE70D;"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="CheckedPressed">
                                                                <VisualState.Setters>
                                                                    <Setter Target="Root.Background"
                                                                            Value="{ThemeResource AJut_Brush_PrimaryHighlightDark}"/>
                                                                    <Setter Target="ExpanderIcon.Glyph"
                                                                            Value="&#xE70D;"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <ContentPresenter Grid.Column="2"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          Margin="2,0"
                                          Content="{Binding .}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
    ===[ FlatTreeListControl - AJut-themed override ]===
    Applies AJut list background/border and the AJut-branded selection strip item style.
    -->
    <Style TargetType="local:FlatTreeListControl">
        <Setter Property="Background" Value="{ThemeResource AJut_Brush_ListBackground}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_ListBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="ExpanderGlyphForeground" Value="{ThemeResource AJut_Brush_SymbolForeground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:FlatTreeListControl">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ListView x:Name="PART_ListView"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  SelectionMode="Single"
                                  ItemTemplate="{StaticResource FlatTree_RowDataTemplate}"
                                  ItemContainerStyle="{StaticResource AJut_FlatTree_ListViewItemStyle}"
                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.Resources>
                                <!-- Suppress WinUI3 ListView host-level selection chrome. -->
                                <SolidColorBrush x:Key="ListViewItemSelectionIndicatorBrush" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemSelectionIndicatorPointerOverBrush" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemSelectionIndicatorPressedBrush" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemSelectionIndicatorDisabledBrush" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedUnfocused" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent"/>
                            </ListView.Resources>
                        </ListView>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
    ===[ PropertyGridItemRow - AJut-themed override ]===
    Restores AJut_Brush_NormalText for the property label.
    -->
    <Style TargetType="local:PropertyGridItemRow">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PropertyGridItemRow">
                    <Grid HorizontalAlignment="Stretch"
                          Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding DisplayName}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontStyle="Italic"
                                   Opacity="0.8"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTipService.ToolTip="{Binding DisplayName}"
                                   Foreground="{ThemeResource AJut_Brush_NormalText}"/>

                        <ContentControl Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Content="{Binding}"
                                        ContentTemplateSelector="{TemplateBinding EditorTemplateSelector}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
    ===[ NumericEditor - AJut-themed override ]===
    Replaces the gradient background with AJut_Brush_PopOutControlBackground.
    Sets FocusBorderBrush so the focused border uses AJut_Brush_PrimaryHighlight
    (handled in code-behind — no template duplication needed).
    Sets hover/pressed highlight brushes to AJut interaction brushes.
    -->
    <Style TargetType="local:NumericEditor">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="{ThemeResource AJut_Brush_PopOutControlBackground}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_TextBoxBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FocusBorderBrush" Value="{ThemeResource AJut_Brush_PrimaryHighlight}"/>
        <Setter Property="IncreaseHoverHighlight" Value="{ThemeResource AJut_Brush_MouseInteractionHighlight}"/>
        <Setter Property="IncreasePressedHighlight" Value="{ThemeResource AJut_Brush_PrimaryHighlightDark}"/>
        <Setter Property="DecreaseHoverHighlight" Value="{ThemeResource AJut_Brush_MouseInteractionHighlight}"/>
        <Setter Property="DecreasePressedHighlight" Value="{ThemeResource AJut_Brush_PrimaryHighlightDark}"/>
    </Style>

    <!--
    ===[ DockLeafLayout - AJut-themed override ]===
    Applies AJut brush tokens to the leaf panel's visual DPs.
    The default colors in DockLeafLayout.xaml remain intact for no-theme usage.
    No template redefinition — only DP setters.
    -->
    <Style TargetType="local:DockLeafLayout">
        <Setter Property="Foreground"           Value="{ThemeResource AJut_Brush_NormalText}"/>
        <Setter Property="PanelBackground"      Value="{ThemeResource AJut_Brush_PanelBackground}"/>
        <Setter Property="PanelBorderBrush"     Value="{ThemeResource AJut_Brush_BorderCommon}"/>
        <Setter Property="PanelBorderThickness" Value="1"/>
        <Setter Property="TabStripBackground"   Value="{ThemeResource AJut_Brush_BannerBackground}"/>
        <!-- TopLeft=0, TopRight=0: flat top merges with header bar.
             BottomRight=8, BottomLeft=8: rounded bottom corners above the tab strip. -->
        <Setter Property="PanelCornerRadius"    Value="0,0,8,8"/>
    </Style>

    <!--
    ===[ DockTabItem - AJut-themed override ]===
    Applies AJut brush tokens to tab item background and border.
    No template redefinition — only DP setters.
    -->
    <Style TargetType="local:DockTabItem">
        <Setter Property="Background"   Value="{ThemeResource AJut_Brush_PanelBackground}"/>
        <Setter Property="BorderBrush"  Value="{ThemeResource AJut_Brush_BorderCommon}"/>
    </Style>

    <!--
    ===[ PathSelectionControl - AJut-themed override ]===
    Applies AJut text-control colors to the path entry container and uses
    AJut_Brush_PrimaryHighlight for the focused border state.
    -->
    <Style TargetType="local:PathSelectionControl">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="{ThemeResource AJut_Brush_PopOutControlBackground}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_TextBoxBorder}"/>
        <Setter Property="BorderThickness" Value="1,1,1,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PathSelectionControl">
                    <Border x:Name="PART_Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0,3,3,0"
                            ToolTipService.ToolTip="{TemplateBinding SelectedPath}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="PART_PathTextBox"
                                     Grid.Column="0"
                                     PlaceholderText="{TemplateBinding UnsetTextPrompt}"
                                     FontFamily="Consolas"
                                     TextWrapping="NoWrap"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     CornerRadius="0"
                                     Padding="6,4"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Center"/>

                            <Border x:Name="PART_WarningDisplay"
                                    Grid.Column="1"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False"
                                    Padding="4,2"
                                    ToolTipService.ToolTip="{TemplateBinding InvalidPathReason}">
                                <FontIcon Glyph="&#xE7BA;"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="14"
                                          Foreground="{ThemeResource AJut_Brush_NormalText}"/>
                            </Border>

                            <Button x:Name="PART_ShowInExplorerButton"
                                    Grid.Column="2"
                                    Visibility="Collapsed"
                                    Padding="10,6"
                                    BorderThickness="1,0,0,0"
                                    BorderBrush="{ThemeResource AJut_Brush_BorderCommon}"
                                    Background="Transparent"
                                    ToolTipService.ToolTip="Show in Explorer">
                                <FontIcon Glyph="{TemplateBinding OpenInExplorerMDL2Icon}"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="14"
                                          Foreground="{ThemeResource AJut_Brush_SymbolForeground}"/>
                            </Button>

                            <Button x:Name="PART_BrowseButton"
                                    Grid.Column="3"
                                    Padding="10,6"
                                    BorderThickness="1,0,0,0"
                                    BorderBrush="{ThemeResource AJut_Brush_BorderCommon}"
                                    Background="Transparent"
                                    ToolTipService.ToolTip="{TemplateBinding BrowsePrompt}">
                                <FontIcon Glyph="{TemplateBinding DefaultButtonMDL2Icon}"
                                          FontFamily="Segoe Fluent Icons"
                                          FontSize="14"
                                          Foreground="{ThemeResource AJut_Brush_SymbolForeground}"/>
                            </Button>
                        </Grid>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="BorderStates">
                                <!-- Normal: explicit revert — WinUI3 Setters do not auto-revert on state exit -->
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="PART_Root.BorderBrush"
                                                Value="{ThemeResource AJut_Brush_TextBoxBorder}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Focused">
                                    <VisualState.Setters>
                                        <Setter Target="PART_Root.BorderBrush"
                                                Value="{ThemeResource AJut_Brush_PrimaryHighlight}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PathInvalid">
                                    <VisualState.Setters>
                                        <Setter Target="PART_Root.BorderBrush"
                                                Value="#C00000"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="WarningDisplayStates">
                                <!-- WarningHidden: explicit revert — WinUI3 Setters do not auto-revert on state exit -->
                                <VisualState x:Name="WarningHidden">
                                    <VisualState.Setters>
                                        <Setter Target="PART_WarningDisplay.Visibility" Value="Collapsed"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="WarningShown">
                                    <VisualState.Setters>
                                        <Setter Target="PART_WarningDisplay.Visibility"
                                                Value="Visible"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="ExplorerButtonStates">
                                <VisualState x:Name="ExplorerButtonHidden"/>
                                <VisualState x:Name="ExplorerButtonShown">
                                    <VisualState.Setters>
                                        <Setter Target="PART_ShowInExplorerButton.Visibility"
                                                Value="Visible"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
    ===[ ColorEditIngressControl - AJut-themed override ]===
    Replaces the hardcoded HighlightBorderBrush with AJut_Brush_PrimaryHighlight
    so the flyout-open border flash matches the rest of the AJut accent system.
    Uses AJut_Brush_BorderCommon for the resting border.
    -->
    <Style TargetType="local:ColorEditIngressControl">
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_BorderCommon}"/>
        <Setter Property="HighlightBorderBrush" Value="{ThemeResource AJut_Brush_PrimaryHighlight}"/>
    </Style>

    <!--
    ===[ PopupMenuButton - AJut-themed override ]===
    Applies AJut border/background to the ToggleButton wrapper.
    The ToggleButton's Checked state uses AJut_Brush_PrimaryHighlight automatically
    via SystemColorAliasing.xaml (ToggleButtonBackgroundChecked override).
    -->
    <Style TargetType="local:PopupMenuButton">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_BorderCommon}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PopupMenuButton">
                    <ToggleButton x:Name="PART_Button"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  Padding="{TemplateBinding Padding}"
                                  HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                  CornerRadius="2">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <ContentControl Content="{TemplateBinding ButtonContent}"
                                            ContentTemplate="{TemplateBinding ButtonContentTemplate}"
                                            IsTabStop="False"
                                            VerticalAlignment="Center"/>
                            <FontIcon Glyph="&#xE972;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="9"
                                      Foreground="{ThemeResource AJut_Brush_SymbolForeground}"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
    ===[ ToggleStrip - AJut-themed override ]===
    Applies AJut strip container colors. Individual ToggleButtons inside the
    strip pick up AJut colors from SystemColorAliasing.xaml automatically.
    -->
    <Style TargetType="local:ToggleStrip">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Background" Value="{ThemeResource AJut_Brush_PopOutControlBackground}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_BorderCommon}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:ToggleStrip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Border.Resources>
                            <!-- AJut-themed "depressed button" gradients for checked ToggleButtons.
                                 Uses a dark overlay with a slight cool tint for the checked state,
                                 matching the AJut aesthetic of depressed/active controls. -->
                            <LinearGradientBrush x:Key="ToggleButtonBackgroundChecked"
                                                 StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.00" Color="#CC000000"/>
                                <GradientStop Offset="0.20" Color="#801090A0"/>
                                <GradientStop Offset="1.00" Color="#331090A0"/>
                            </LinearGradientBrush>
                            <LinearGradientBrush x:Key="ToggleButtonBackgroundCheckedPointerOver"
                                                 StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.00" Color="#CC000000"/>
                                <GradientStop Offset="0.20" Color="#991090A0"/>
                                <GradientStop Offset="1.00" Color="#551090A0"/>
                            </LinearGradientBrush>
                            <LinearGradientBrush x:Key="ToggleButtonBackgroundCheckedPressed"
                                                 StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.00" Color="#EE000000"/>
                                <GradientStop Offset="0.20" Color="#AA1090A0"/>
                                <GradientStop Offset="1.00" Color="#661090A0"/>
                            </LinearGradientBrush>
                        </Border.Resources>
                        <StackPanel x:Name="PART_ItemsPanel"
                                    Orientation="Horizontal"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
