<?xml version="1.0" encoding="utf-8"?>
<!--
    AllControlThemeOverrides.xaml
    ==============================
    Merge this dictionary (along with a DarkThemeColorsBase.xaml or LightThemeColorsBase.xaml)
    into your Application.Resources to apply AJut theme colors to the AJut.UX.WinUI3 controls.

    The default control styles (in Generic.xaml / the individual Control XAML files) use only
    WinUI3 built-in system brushes and literal values so that controls work without any AJut
    theme loaded. Merging this dictionary overrides the relevant parts with AJut brush keys.

    Merge order in App.xaml (after a theme color dictionary):
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/DarkThemeColorsBase.xaml"/>
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/AllControlThemeOverrides.xaml"/>
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:AJut.UX.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/Microsoft.UI.Xaml_Overrides.xaml"/>
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/AJut.UX_Overrides.xaml"/>
        <ResourceDictionary Source="ms-appx:///AJut.UX.WinUI3/Resources/AJutThemeMapAliasing.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!--
    ===[ FlatTreeListControl - AJut-themed override ]===
    Applies AJut list background/border. No template duplication needed.
    AJut_FlatTree_ListViewItemStyle template lives only in FlatTreeListControl.xaml;
    brush keys are redirected via AJutThemeMapAliasing.xaml.
    -->
    <Style TargetType="local:FlatTreeListControl">
        <Setter Property="Background" Value="{ThemeResource AJut_Brush_ListBackground}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_ListBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="ExpanderGlyphForeground" Value="{ThemeResource AJut_Brush_SymbolForeground}"/>
    </Style>

    <!--
    ===[ NumericEditor - AJut-themed override ]===
    Redefines control-specific ThemeResource keys. No template duplication needed.
    Brush key redirects in AJutThemeMapAliasing.xaml handle focus/hover/pressed colors.
    -->
    <Style TargetType="local:NumericEditor">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="{ThemeResource AJut_Brush_PopOutControlBackground}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="TextBoxBackground" Value="{ThemeResource AJut_Brush_TextBoxBackground}"/>
    </Style>

    <!--
    ===[ DockTearoffContainerPanel - AJut-themed override ]===
    Overrides the default ApplicationPageBackgroundThemeBrush with the AJut panel
    background so the tearoff window background matches the docked panels.
    -->
    <Style TargetType="local:DockTearoffContainerPanel">
        <Setter Property="Background" Value="{ThemeResource AJut_Brush_PanelBackground}"/>
    </Style>

    <!--
    ===[ DockLeafLayout - AJut-themed override ]===
    Applies AJut brush tokens to the leaf panel's visual DPs.
    The default colors in DockLeafLayout.xaml remain intact for no-theme usage.
    No template redefinition — only DP setters.
    -->
    <Style TargetType="local:DockLeafLayout">
        <Setter Property="Foreground"           Value="{ThemeResource AJut_Brush_NormalText}"/>
        <Setter Property="PanelBackground"      Value="{ThemeResource AJut_Brush_PanelBackground}"/>
        <Setter Property="PanelBorderBrush"     Value="{ThemeResource AJut_Brush_BorderCommon}"/>
        <Setter Property="PanelBorderThickness" Value="1"/>
        <Setter Property="TabStripBackground"   Value="Transparent"/>
        <!-- TopLeft=0, TopRight=0: flat top merges with header bar.
             BottomRight=8, BottomLeft=8: rounded bottom corners above the tab strip. -->
        <Setter Property="PanelCornerRadius"    Value="0,0,8,8"/>
    </Style>

    <!--
    ===[ DockTabItem - AJut-themed override ]===
    Applies AJut brush tokens to tab item background and border.
    No template redefinition — only DP setters.
    -->
    <Style TargetType="local:DockTabItem">
        <Setter Property="Background"   Value="{ThemeResource AJut_Brush_PanelBackground}"/>
        <Setter Property="BorderBrush"  Value="{ThemeResource AJut_Brush_BorderCommon}"/>
    </Style>

    <!--
    ===[ PathSelectionControl - AJut-themed override ]===
    Redefines control-specific ThemeResource keys. No template duplication needed.
    -->
    <Style TargetType="local:PathSelectionControl">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="{ThemeResource AJut_Brush_PopOutControlBackground}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_TextBoxBorder}"/>
        <Setter Property="BorderThickness" Value="1,1,1,2"/>
    </Style>

    <!--
    ===[ ColorEditIngressControl - AJut-themed override ]===
    Redefines EditingStates border brush keys. No template duplication needed.
    AJut_ColorEditIngressControl_HighlightBorderBrush → AJut_Brush_PrimaryHighlight
    AJut_ColorEditIngressControl_NormalBorderBrush    → AJut_Brush_BorderCommon
    -->
    <Style TargetType="local:ColorEditIngressControl">
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_BorderCommon}"/>
    </Style>

    <!--
    ===[ PopupMenuButton - AJut-themed override ]===
    Redefines chevron glyph foreground key. No template duplication needed.
    -->
    <Style TargetType="local:PopupMenuButton">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_BorderCommon}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <!--
    ===[ ToggleStrip - AJut-themed override ]===
    ToggleStripButton controls handle all button-level visual states via ThemeResource
    keys (redirected in AJutThemeMapAliasing.xaml). The strip container only needs
    AJut brush assignments. No template duplication needed.
    -->
    <Style TargetType="local:ToggleStrip">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Background" Value="{ThemeResource AJut_Brush_PopOutControlBackground}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource AJut_Brush_BorderCommon}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ItemPadding" Value="8,4"/>
    </Style>

</ResourceDictionary>
