<?xml version="1.0" encoding="utf-8"?>
<!--
    AJutThemeMapAliasing.xaml
    ==========================
    Merged into AllControlThemeOverrides.xaml (which lives in App.Resources flat).
    Maps control-specific ThemeResource keys to AJut palette colors.

    All entries use SolidColorBrush Color="{ThemeResource AJut_Color_*}" (runtime lookup)
    instead of StaticResource (parse-time lookup). StaticResource cannot reach ThemeDictionary
    entries from a flat App.Resources merged dictionary; {ThemeResource} resolves them at
    runtime from App.Resources.ThemeDictionaries for the current theme.

    When no AJut theme is loaded (AllControlThemeOverrides.xaml not merged), controls need
    AJutCustomControlStylingDefaults.xaml to be in App.Resources (via AJutControlsResources
    or an explicit merge). Generic.xaml ThemeDictionaries["Default"] is NOT searched by
    runtime GoToState {ThemeResource} lookups - only App.Resources is.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===========[ DockDropInsertionDriverWidget ]========================== -->
    <SolidColorBrush x:Key="AJut_DockDropInsertionDriverWidget_BorderIdleBrush"        Color="{ThemeResource AJut_Color_BorderCommon}"/>
    <SolidColorBrush x:Key="AJut_DockDropInsertionDriverWidget_BackgroundIdleBrush"    Color="{ThemeResource AJut_Color_PanelBackground}"/>
    <SolidColorBrush x:Key="AJut_DockDropInsertionDriverWidget_GlyphIdleBrush"         Color="{ThemeResource AJut_Color_SymbolForeground}"/>
    <SolidColorBrush x:Key="AJut_DockDropInsertionDriverWidget_BorderEngagedBrush"     Color="{ThemeResource AJut_Color_BorderCommon}"/>
    <SolidColorBrush x:Key="AJut_DockDropInsertionDriverWidget_BackgroundEngagedBrush" Color="{ThemeResource AJut_Color_PrimaryHighlight}"/>
    <SolidColorBrush x:Key="AJut_DockDropInsertionDriverWidget_GlyphEngagedBrush"      Color="{ThemeResource AJut_Color_SymbolForegroundHighlight}"/>

    <!-- ===========[ DockTearoffContainerPanel ]========================== -->
    <SolidColorBrush x:Key="AJut_DockTearoffContainerPanel_TitleBarBackground" Color="{ThemeResource AJut_Color_TitleBarBackground}"/>
    <SolidColorBrush x:Key="AJut_DockTearoffContainerPanel_TitleBarForeground" Color="{ThemeResource AJut_Color_TitleBarForeground}"/>
    <!-- Chrome close button - use ChromeClose color keys (distinct from standard close) -->
    <SolidColorBrush x:Key="AJut_DockTearoffContainerPanel_CloseButtonHoverBackground"   Color="{ThemeResource AJut_Color_ChromeCloseButtonHoverBackground}"/>
    <SolidColorBrush x:Key="AJut_DockTearoffContainerPanel_CloseButtonPressedBackground" Color="{ThemeResource AJut_Color_ChromeCloseButtonPressedBackground}"/>

    <!-- ===========[ PropertyGridItemRow ]================================
         SelectionBorderBrush → ListSelection (solid accent, same as FlatTree nub/strip).
         HoverBackground      → ListSelectionBackground (10% opacity fill, same as FlatTree hover fill).
         HoverBorderBrush     → BorderCommon (neutral 1px outline, same as FlatTree hover border). -->
    <SolidColorBrush x:Key="AJut_PropertyGridItemRow_LabelForeground"      Color="{ThemeResource AJut_Color_NormalText}"/>
    <SolidColorBrush x:Key="AJut_PropertyGridItemRow_SelectionBorderBrush" Color="{ThemeResource AJut_Color_ListSelection}"/>
    <SolidColorBrush x:Key="AJut_PropertyGridItemRow_HoverBackground"      Color="{ThemeResource AJut_Color_ListSelectionBackground}"/>
    <SolidColorBrush x:Key="AJut_PropertyGridItemRow_HoverBorderBrush"     Color="{ThemeResource AJut_Color_BorderCommon}"/>

    <!-- ===========[ PopupMenuButton ]===================================== -->
    <SolidColorBrush x:Key="AJut_PopupMenuButton_ChevronForeground" Color="{ThemeResource AJut_Color_SymbolForeground}"/>

    <!-- ===========[ PathSelectionControl ]================================ -->
    <SolidColorBrush x:Key="AJut_PathSelectionControl_NormalBorderBrush"             Color="{ThemeResource AJut_Color_TextBoxBorder}"/>
    <SolidColorBrush x:Key="AJut_PathSelectionControl_FocusedBorderBrush"            Color="{ThemeResource AJut_Color_PrimaryHighlight}"/>
    <SolidColorBrush x:Key="AJut_PathSelectionControl_WarningIconForeground"         Color="{ThemeResource AJut_Color_NormalText}"/>
    <SolidColorBrush x:Key="AJut_PathSelectionControl_ButtonBorderBrush"             Color="{ThemeResource AJut_Color_BorderCommon}"/>
    <SolidColorBrush x:Key="AJut_PathSelectionControl_ButtonIconForeground"          Color="{ThemeResource AJut_Color_SymbolForeground}"/>
    <SolidColorBrush x:Key="AJut_PathSelectionControl_FocusedTextBoxBackgroundBrush" Color="{ThemeResource AJut_Color_TextBoxBackground}"/>

    <!-- ===========[ FlatTreeItemRow ]===================================== -->
    <SolidColorBrush x:Key="AJut_FlatTreeItemRow_ExpanderPointerOverBackground" Color="{ThemeResource AJut_Color_MouseInteractionHighlight}"/>
    <SolidColorBrush x:Key="AJut_FlatTreeItemRow_ExpanderPressedBackground"     Color="{ThemeResource AJut_Color_PrimaryHighlightDark}"/>

    <!-- ===========[ FlatTree ListViewItem ]=============================== -->
    <!-- Redirects selection/hover to AJut palette colors.
         HoverBackground → ListSelectionBackground (10% opacity tint, matches PropertyGrid row hover). -->
    <SolidColorBrush x:Key="AJut_FlatTree_SelectionBrush"          Color="{ThemeResource AJut_Color_ListSelection}"/>
    <SolidColorBrush x:Key="AJut_FlatTree_SelectionBackground"     Color="{ThemeResource AJut_Color_ListSelectionBackground}"/>
    <SolidColorBrush x:Key="AJut_FlatTree_SelectionBrushUnfocused" Color="{ThemeResource AJut_Color_PrimaryHighlightDesat}"/>
    <SolidColorBrush x:Key="AJut_FlatTree_HoverBackground"         Color="{ThemeResource AJut_Color_ListSelectionBackground}"/>
    <SolidColorBrush x:Key="AJut_FlatTree_HoverBorderBrush"        Color="{ThemeResource AJut_Color_BorderCommon}"/>

    <!-- ===========[ ColorEditIngressControl ]============================= -->
    <SolidColorBrush x:Key="AJut_ColorEditIngressControl_HighlightBorderBrush" Color="{ThemeResource AJut_Color_PrimaryHighlight}"/>
    <SolidColorBrush x:Key="AJut_ColorEditIngressControl_NormalBorderBrush"    Color="{ThemeResource AJut_Color_BorderCommon}"/>

    <!-- ===========[ DockCloseButton ]===================================== -->
    <SolidColorBrush x:Key="AJut_DockCloseButton_HoverBackground"   Color="{ThemeResource AJut_Color_MouseInteractionHighlight}"/>
    <SolidColorBrush x:Key="AJut_DockCloseButton_PressedBackground" Color="{ThemeResource AJut_Color_PrimaryHighlightDark}"/>

    <!-- ===========[ DockTabScrollButton ]================================= -->
    <SolidColorBrush x:Key="AJut_DockTabScrollButton_HoverBackground"   Color="{ThemeResource AJut_Color_MouseInteractionHighlight}"/>
    <SolidColorBrush x:Key="AJut_DockTabScrollButton_PressedBackground" Color="{ThemeResource AJut_Color_PrimaryHighlightDark}"/>

    <!-- ===========[ NullableEditor ]====================================== -->
    <!-- OverlayBackground is intentionally not aliased: it's a semi-transparent dark overlay
         (#30000000) that works on any theme. The Generic.xaml default is used as-is. -->
    <SolidColorBrush x:Key="AJut_NullableEditor_NotSetForeground" Color="{ThemeResource AJut_Color_NormalText}"/>
    <SolidColorBrush x:Key="AJut_NullableEditor_OverlayBackground"  Color="#8000"/>

    <!-- ===========[ NumericEditor ]======================================= -->
    <SolidColorBrush x:Key="AJut_NumericEditor_IncreasePointerOverBackground" Color="{ThemeResource AJut_Color_PrimaryHighlightBright}"/>
    <SolidColorBrush x:Key="AJut_NumericEditor_DecreasePointerOverBackground" Color="{ThemeResource AJut_Color_PrimaryHighlightBright}"/>
    <SolidColorBrush x:Key="AJut_NumericEditor_FocusBorderBrush"              Color="{ThemeResource AJut_Color_PrimaryHighlight}"/>
    <SolidColorBrush x:Key="AJut_NumericEditor_NormalBorderBrush"             Color="{ThemeResource AJut_Color_BorderCommon}"/>

    <!-- ===========[ ToggleStripButton ]==================================== -->
    <!-- Unchecked hover/press: map to AJut highlight colors -->
    <SolidColorBrush x:Key="AJut_ToggleStripButton_PointerOverBackground" Color="{ThemeResource AJut_Color_PrimaryHighlightBright}"/>
    <SolidColorBrush x:Key="AJut_ToggleStripButton_PressedBackground"     Color="{ThemeResource AJut_Color_PrimaryHighlightDark}"/>
    <!-- Checked: AJut cool-dark gradients with teal tint (#1090A0) to distinguish active state -->
    <LinearGradientBrush x:Key="AJut_ToggleStripButton_CheckedBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.00" Color="#CC000000"/>
        <GradientStop Offset="0.20" Color="#801090A0"/>
        <GradientStop Offset="1.00" Color="#331090A0"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AJut_ToggleStripButton_CheckedPointerOverBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.00" Color="#CC000000"/>
        <GradientStop Offset="0.20" Color="#991090A0"/>
        <GradientStop Offset="1.00" Color="#551090A0"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AJut_ToggleStripButton_CheckedPressedBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.00" Color="#EE000000"/>
        <GradientStop Offset="0.20" Color="#AA1090A0"/>
        <GradientStop Offset="1.00" Color="#661090A0"/>
    </LinearGradientBrush>

</ResourceDictionary>
