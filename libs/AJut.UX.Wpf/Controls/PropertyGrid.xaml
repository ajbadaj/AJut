<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ajut="clr-namespace:AJut.UX"
                    xmlns:ap="clr-namespace:AJut.UX.AttachedProperties"
                    xmlns:local="clr-namespace:AJut.UX.Controls"
                    xmlns:conv="clr-namespace:AJut.UX.Converters"
                    xmlns:prop="clr-namespace:AJut.UX.PropertyInteraction;assembly=AJut.UX">

    <!-- ===[ PropertyGrid: no-selection ListBoxItem style ]=== -->
    <!-- Suppresses ListBox full-row selection highlight so the label-border selection
         (DataTrigger on IsSelected in the ItemTemplate) is the only visual indicator. -->
    <Style x:Key="PropertyGrid_NoSelectionListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border Padding="2" SnapsToDevicePixels="True" Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Stretch"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===[ Default subtitle style ]=== -->
    <Style x:Key="PropertyGrid_DefaultSubtitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="Opacity" Value="0.85"/>
        <Setter Property="Margin" Value="5,0,7,2"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <!-- Converter: collapses the subtitle when it is null or empty. Note: the property names
         in IsTextNullOrEmptyToVisibilityConverter are inverted relative to the condition, so
         WhenHasText=Collapsed means "when text IS null/empty, collapse". -->
    <conv:IsTextNullOrEmptyToVisibilityConverter x:Key="PG_SubtitleVisConverter"
                                                  WhenHasText="Collapsed"
                                                  WhenNullOrEmpty="Visible"/>

    <!-- Label icon converters -->
    <conv:StringToImageSourceConverter x:Key="PG_StringToImageSource"/>
    <conv:IsTextNullOrEmptyToVisibilityConverter x:Key="PG_IconVisConverter"
                                                  WhenHasText="Collapsed"
                                                  WhenNullOrEmpty="Visible"/>
    <conv:ThicknessFromNumberConverter x:Key="PG_IconMarginConverter" MultiplyMask="1,1,1,1"/>

    <!-- ===[ Default label templates ]=== -->
    <!-- DefaultValueLabelDataTemplate: normal label (value equals default). DataContext = PropertyEditTarget. -->
    <DataTemplate x:Key="PropertyGrid_DefaultLabelTemplate" DataType="{x:Type prop:PropertyEditTarget}">
        <StackPanel VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding IconSource, Converter={StaticResource PG_StringToImageSource}}"
                       Visibility="{Binding IconSource, Converter={StaticResource PG_IconVisConverter}}"
                       Margin="{Binding IconMargin, Converter={StaticResource PG_IconMarginConverter}}"
                       MaxHeight="20"
                       VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DisplayName}"
                           Margin="5,3,7,0"/>
            </StackPanel>
            <TextBlock Text="{Binding Subtitle}"
                       Visibility="{Binding Subtitle, Converter={StaticResource PG_SubtitleVisConverter}}"
                       Style="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=LabelSubtitleStyle}"/>
        </StackPanel>
    </DataTemplate>

    <!-- ModifiedValueLabelDataTemplate: bold label (value differs from default). DataContext = PropertyEditTarget. -->
    <DataTemplate x:Key="PropertyGrid_ModifiedLabelTemplate" DataType="{x:Type prop:PropertyEditTarget}">
        <StackPanel VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding IconSource, Converter={StaticResource PG_StringToImageSource}}"
                       Visibility="{Binding IconSource, Converter={StaticResource PG_IconVisConverter}}"
                       Margin="{Binding IconMargin, Converter={StaticResource PG_IconMarginConverter}}"
                       MaxHeight="20"
                       VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DisplayName}"
                           FontWeight="Bold"
                           Margin="5,3,7,0"/>
            </StackPanel>
            <TextBlock Text="{Binding Subtitle}"
                       Visibility="{Binding Subtitle, Converter={StaticResource PG_SubtitleVisConverter}}"
                       Style="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=LabelSubtitleStyle}"/>
        </StackPanel>
    </DataTemplate>

    <Style TargetType="{x:Type local:PropertyGrid}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="TextLabelStyle">
            <Setter.Value>
                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="Opacity" Value="0.8"/>
                    <Setter Property="FontStyle" Value="Italic"/>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="DefaultValueLabelDataTemplate" Value="{StaticResource PropertyGrid_DefaultLabelTemplate}"/>
        <Setter Property="ModifiedValueLabelDataTemplate" Value="{StaticResource PropertyGrid_ModifiedLabelTemplate}"/>
        <Setter Property="LabelSubtitleStyle" Value="{StaticResource PropertyGrid_DefaultSubtitleStyle}"/>
        <Setter Property="BorderBrush" Value="Gray"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:PropertyGrid}">
                    <!--
                        RootItemsSource = PropertyTreeItems (top-level PropertyEditTarget items).
                        FlatTreeListControl.CreateUberRoot wraps each in a FlatTreeItem with the
                        uber root always expanded, making all top-level rows immediately visible.
                        Sub-object children start collapsed until the user expands them.
                        Note: the WPF FlatTreeListControl ItemTemplate DataContext is PropertyEditTarget
                        (set by the inner ContentPresenter via Content="{Binding Source}"). To access
                        IndentWidth we walk to the ListBoxItem (DataContext = FlatTreeItem).
                    -->
                    <local:FlatTreeListControl RootItemsSource="{ajut:TemplateBinding PropertyTreeItems}"
                                               Background="{TemplateBinding Background}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               ap:BorderXTA.CornerRadius="{ajut:TemplateBinding Path=(ap:BorderXTA.CornerRadius)}"
                                               HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                               TreeDepthIndentSize="{TemplateBinding TreeDepthIndentSize}"
                                               RowSpacing="{TemplateBinding RowSpacing}"
                                               FixedRowHeight="{TemplateBinding FixedRowHeight}"
                                               ListBoxItemContainerStyle="{StaticResource PropertyGrid_NoSelectionListBoxItemStyle}"
                                               ScrollViewer.HorizontalScrollBarVisibility="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=(ScrollViewer.HorizontalScrollBarVisibility)}"
                                               ScrollViewer.VerticalScrollBarVisibility="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=(ScrollViewer.VerticalScrollBarVisibility)}">
                        <local:FlatTreeListControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type prop:PropertyEditTarget}">
                                <Grid Margin="3">
                                    <Grid.ColumnDefinitions>
                                        <!-- Label column: fixed when LabelColumnWidth is set (accounts for
                                             indent), Auto (SharedSizeGroup) otherwise. IndentWidth is on the
                                             FlatTreeItem, accessed through the ListBoxItem.DataContext. -->
                                        <ColumnDefinition SharedSizeGroup="Header">
                                            <ColumnDefinition.Width>
                                                <MultiBinding Converter="{conv:LabelWidthAfterIndentConverter}">
                                                    <Binding RelativeSource="{RelativeSource AncestorType=ListBoxItem}" Path="DataContext.IndentWidth"/>
                                                    <Binding RelativeSource="{RelativeSource AncestorType=local:PropertyGrid}" Path="LabelColumnWidth"/>
                                                </MultiBinding>
                                            </ColumnDefinition.Width>
                                        </ColumnDefinition>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Label with selection highlight and right-click context menu.
                                         ContentPresenter switches between DefaultValueLabelDataTemplate and
                                         ModifiedValueLabelDataTemplate based on PropertyEditTarget.IsAtDefaultValue.
                                         DataContext for both templates is the PropertyEditTarget. -->
                                    <Border Grid.Column="0" Margin="0,0,3,0">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{Binding RelativeSource={RelativeSource AncestorType=local:FlatTreeListControl}, Path=SelectionBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ContextMenu>
                                            <!-- DataContext bound via PlacementTarget so {Binding} reaches PropertyEditTarget. -->
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="Set to default"
                                                          Command="{x:Static local:PropertyGrid.SetPropertyToDefaultCommand}"
                                                          CommandParameter="{Binding}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>

                                        <!-- Label content: switches template based on IsAtDefaultValue.
                                             Content={Binding} passes PropertyEditTarget as the template's DataContext. -->
                                        <ContentPresenter Content="{Binding}">
                                            <ContentPresenter.Style>
                                                <Style TargetType="{x:Type ContentPresenter}">
                                                    <!-- Default: ModifiedValueLabelDataTemplate (value changed from default) -->
                                                    <Setter Property="ContentTemplate"
                                                            Value="{Binding RelativeSource={RelativeSource AncestorType=local:PropertyGrid}, Path=ModifiedValueLabelDataTemplate}"/>
                                                    <Style.Triggers>
                                                        <!-- Switch to DefaultValueLabelDataTemplate when at default -->
                                                        <DataTrigger Binding="{Binding IsAtDefaultValue}" Value="True">
                                                            <Setter Property="ContentTemplate"
                                                                    Value="{Binding RelativeSource={RelativeSource AncestorType=local:PropertyGrid}, Path=DefaultValueLabelDataTemplate}"/>
                                                        </DataTrigger>
                                                        <!-- Expandable parent nodes always use the default-value template -
                                                             their object reference is never meaningfully compared to a default. -->
                                                        <DataTrigger Binding="{Binding IsExpandable}" Value="True">
                                                            <Setter Property="ContentTemplate"
                                                                    Value="{Binding RelativeSource={RelativeSource AncestorType=local:PropertyGrid}, Path=DefaultValueLabelDataTemplate}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ContentPresenter.Style>
                                        </ContentPresenter>
                                    </Border>

                                    <!-- Editor: uses EffectiveEditorTarget so elevation is transparent.
                                         Hidden when the row is expandable with no inline editor. -->
                                    <ContentPresenter Grid.Column="1"
                                                      VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=VerticalContentAlignment}"
                                                      HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=HorizontalContentAlignment}"
                                                      ContentTemplateSelector="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=ItemTemplateSelector}"
                                                      Content="{Binding EffectiveEditorTarget}">
                                        <ContentPresenter.Style>
                                            <Style TargetType="{x:Type ContentPresenter}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasInlineEditor}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentPresenter.Style>
                                    </ContentPresenter>
                                </Grid>
                            </DataTemplate>
                        </local:FlatTreeListControl.ItemTemplate>
                    </local:FlatTreeListControl>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
