<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ajut="clr-namespace:AJut.UX"
                    xmlns:ap="clr-namespace:AJut.UX.AttachedProperties"
                    xmlns:local="clr-namespace:AJut.UX.Controls"
                    xmlns:conv="clr-namespace:AJut.UX.Converters"
                    xmlns:prop="clr-namespace:AJut.UX.PropertyInteraction;assembly=AJut.UX">

    <!-- ===[ PropertyGrid: no-selection ListBoxItem style ]=== -->
    <!-- Suppresses ListBox full-row selection highlight so the label-border selection
         (DataTrigger on IsSelected in the ItemTemplate) is the only visual indicator. -->
    <Style x:Key="PropertyGrid_NoSelectionListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border Padding="2" SnapsToDevicePixels="True" Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Stretch"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:PropertyGrid}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="TextLabelStyle">
            <Setter.Value>
                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                    <Setter Property="Opacity" Value="0.8"/>
                    <Setter Property="FontStyle" Value="Italic"/>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="Gray"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:PropertyGrid}">
                    <!--
                        RootItemsSource = PropertyTreeItems (top-level PropertyEditTarget items).
                        FlatTreeListControl.CreateUberRoot wraps each in a FlatTreeItem with the
                        uber root always expanded, making all top-level rows immediately visible.
                        Sub-object children start collapsed until the user expands them.
                        Note: the WPF FlatTreeListControl ItemTemplate DataContext is PropertyEditTarget
                        (set by the inner ContentPresenter via Content="{Binding Source}"). To access
                        IndentWidth we walk to the ListBoxItem (DataContext = FlatTreeItem).
                    -->
                    <local:FlatTreeListControl RootItemsSource="{ajut:TemplateBinding PropertyTreeItems}"
                                               Background="{TemplateBinding Background}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               ap:BorderXTA.CornerRadius="{ajut:TemplateBinding Path=(ap:BorderXTA.CornerRadius)}"
                                               HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                               TreeDepthIndentSize="{TemplateBinding TreeDepthIndentSize}"
                                               RowSpacing="{TemplateBinding RowSpacing}"
                                               FixedRowHeight="{TemplateBinding FixedRowHeight}"
                                               ListBoxItemContainerStyle="{StaticResource PropertyGrid_NoSelectionListBoxItemStyle}"
                                               ScrollViewer.HorizontalScrollBarVisibility="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=(ScrollViewer.HorizontalScrollBarVisibility)}"
                                               ScrollViewer.VerticalScrollBarVisibility="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=(ScrollViewer.VerticalScrollBarVisibility)}">
                        <local:FlatTreeListControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type prop:PropertyEditTarget}">
                                <Grid Margin="3">
                                    <Grid.ColumnDefinitions>
                                        <!-- Label column: fixed when LabelColumnWidth is set (accounts for
                                             indent), Auto (SharedSizeGroup) otherwise. IndentWidth is on the
                                             FlatTreeItem, accessed through the ListBoxItem.DataContext. -->
                                        <ColumnDefinition SharedSizeGroup="Header">
                                            <ColumnDefinition.Width>
                                                <MultiBinding Converter="{conv:LabelWidthAfterIndentConverter}">
                                                    <Binding RelativeSource="{RelativeSource AncestorType=ListBoxItem}" Path="DataContext.IndentWidth"/>
                                                    <Binding RelativeSource="{RelativeSource AncestorType=local:PropertyGrid}" Path="LabelColumnWidth"/>
                                                </MultiBinding>
                                            </ColumnDefinition.Width>
                                        </ColumnDefinition>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Label with selection highlight.
                                         ListBoxItem.IsSelected is still tracked even though the
                                         ListBoxItem template has no selection chrome.
                                         NOTE: No Background attribute here — local value would
                                         override the DataTrigger (WPF DP precedence). -->
                                    <Border Grid.Column="0" Margin="0,0,3,0">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{Binding RelativeSource={RelativeSource AncestorType=local:FlatTreeListControl}, Path=SelectionBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Path=DisplayName, Mode=OneWay}"
                                                   VerticalAlignment="Center"
                                                   Margin="5,3,7,3"
                                                   Style="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=TextLabelStyle}"/>
                                    </Border>

                                    <!-- Editor: uses EffectiveEditorTarget so elevation is transparent.
                                         Hidden when the row is expandable with no inline editor. -->
                                    <ContentPresenter Grid.Column="1"
                                                      VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=VerticalContentAlignment}"
                                                      HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=HorizontalContentAlignment}"
                                                      ContentTemplateSelector="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PropertyGrid}}, Path=ItemTemplateSelector}"
                                                      Content="{Binding EffectiveEditorTarget}">
                                        <ContentPresenter.Style>
                                            <Style TargetType="{x:Type ContentPresenter}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasInlineEditor}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentPresenter.Style>
                                    </ContentPresenter>
                                </Grid>
                            </DataTemplate>
                        </local:FlatTreeListControl.ItemTemplate>
                    </local:FlatTreeListControl>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
